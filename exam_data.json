        window.triggerHaptic = function(type) {
            if (!navigator.vibrate) return;
            try {
                if (type === 'correct') navigator.vibrate([30, 50, 30]); 
                else if (type === 'wrong') navigator.vibrate([150, 50, 150]); 
                else if (type === 'tap') navigator.vibrate(20); 
            } catch(e) {}
        };

