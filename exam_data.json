        window.renderTypeView = function() {
            const container = document.getElementById('type-learning-content');
            const grouped = window.hanjaData.reduce((acc, curr) => { if (curr.typeNo) { if (!acc[curr.typeNo]) acc[curr.typeNo] = []; acc[curr.typeNo].push(curr); } return acc; }, {});
            const keys = Object.keys(grouped).sort((a,b) => parseInt(a) - parseInt(b));
            let pagination = Array.from({length: 10}, (_, i) => `<button onclick="window.renderTypePage(${i})" class="btn-neumorphic text-[11px] px-2.5 py-1 flex-shrink-0 ${i === window.currentTypePage ? 'active' : ''}">${i*20+1}-${(i+1)*20}</button>`).join('');

            let html = `<div class="control-panel mb-5 overflow-x-auto flex flex-nowrap gap-1.5 px-2 py-2 no-scrollbar">${pagination}</div><div id="type-groups-list" class="space-y-5 px-1 pb-10">`;
            
            const keysForPage = keys.filter(key => parseInt(key) >= window.currentTypePage * 20 + 1 && parseInt(key) <= (window.currentTypePage + 1) * 20);
            for (const t of keysForPage) {
                const group = grouped[t], rep = group[0];
                let related = group.slice(1).map(h => `
                    <div class="relative w-[40px] h-[40px] bg-white border border-gray-200 rounded-lg shadow-sm cursor-pointer select-none" data-hanjadata="${encodeURIComponent(JSON.stringify(h))}" onclick="window.handleSubHanjaTap(this)">
