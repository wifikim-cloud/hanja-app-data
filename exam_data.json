            }
            el.dataset.lasttap = new Date().getTime();
        };

        // 제미나이 AI 통합 API
        async function callGeminiAPI(prompt, isJson = false, base64Image = null) {
            const apiKey = ""; 
            
            let parts = [{ text: prompt }];
            if (base64Image) {
                parts.push({ inlineData: { mimeType: "image/jpeg", data: base64Image } });
            }
            
            const payload = { contents: [{ parts: parts }] };

            let retries = 5;
            let delay = 1000;
            while(retries > 0) {
                try {
                    const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, { 
                        method: 'POST', 
                        headers: { 'Content-Type': 'application/json' }, 
                        body: JSON.stringify(payload) 
                    });
                    if(!res.ok) throw new Error('API Request Failed');
                    const data = await res.json();
                    
                    let text = data.candidates?.[0]?.content?.parts?.[0]?.text || "";
                    if(!isJson) text = text.replace(/\n/g, '<br>');
                    return text;
                    
                } catch(e) {
                    retries--;
                    if(retries === 0) return "";
                    await new Promise(r => setTimeout(r, delay));
                    delay *= 2; 
                }
            }
            return "";
        }

        // 안전한 JSON 파싱 헬퍼 함수
        function extractJSON(text) {
            let clean = text;
            const startIdx = clean.indexOf('{');
            const endIdx = clean.lastIndexOf('}');
            if (startIdx !== -1 && endIdx !== -1) {
                clean = clean.substring(startIdx, endIdx + 1);
            } else {
                clean = clean.replace(/`{3}(?:json)?/gi, '').trim();
            }
            return clean;
        }

        async function fetchAllData() {
            try {
                const res = await fetch('https://wifikim-cloud.github.io/hanja-app-data/hanja_data.json');
                const json = await res.json();
                window.hanjaData = json.slice(1).map(item => {
                    let lvl = item.C ? String(item.C).trim() : '';
                    if(['8','7','6','5','4','3','2'].includes(lvl)) lvl += '급';
                    return { 
                        no: parseInt(item.A, 10), 
                        hanja: item.B ? String(item.B).trim() : '', 
                        level: lvl, 
                        typeNo: parseInt(item.D, 10) || 0, 
                        huneum: item.E ? String(item.E).trim() : '', 
                        paja: item.F ? String(item.F).trim() : '', 
                        amgi: item.H ? String(item.H).trim() : '', 
                        explanation: item.I ? String(item.I).trim() : '', 
                        similarHanja: item.J ? String(item.J).trim() : '', 
                        synonyms: item.K ? String(item.K).trim() : '', 
                        antonyms: item.L ? String(item.L).trim() : '',
                        textbookWords: item.N ? String(item.N).trim() : '' 
                    };
                });
                window.hanjaMap = new Map(window.hanjaData.map(h => [h.hanja.normalize('NFKC'), h]));
            } catch (e) { 
                if(DOM.loadingStatus) DOM.loadingStatus.textContent = "데이터 로딩 오류!"; 
            }
        }

        window.openNaverHanja = function(query) {
            window.triggerHaptic('tap');
            const url = `https://hanja.dict.naver.com/search?query=${encodeURIComponent(query)}`;
            window.open(url, '_blank');
        };

        function initApp() {
            window.cards = {
                prev: document.getElementById('card-prev'),
                current: document.getElementById('card-current'),
                next: document.getElementById('card-next')
            };
            
            document.body.addEventListener('click', () => {
                if(audioCtx.state === 'suspended') audioCtx.resume();
            }, {once: true});

            document.querySelector('#sidebar-mode-selector').addEventListener('click', e => {
                const btn = e.target.closest('button'); if(!btn) return;
                window.currentMode = btn.dataset.mode;
                window.updateTopTitle();
                document.querySelectorAll('#sidebar-mode-selector button').forEach(b => b.classList.remove('active', 'text-accent-cyan-dark', 'text-purple-600')); 
                
                if (window.currentMode === 'arcade') btn.classList.add('active', 'text-purple-600');
                else btn.classList.add('active', 'text-accent-cyan-dark');
                
                window.stopArcade();

                if(window.currentMode === 'quiz') { 
                    window.showView('quiz-view');
                    document.getElementById('quiz-intro').classList.remove('hidden');
                    document.getElementById('quiz-container').classList.add('hidden');
                    document.getElementById('quiz-result').classList.add('hidden');
                    const targetLevelEl = document.getElementById('quiz-target-level');
                    if (targetLevelEl) targetLevelEl.textContent = window.currentLevel;
                }
                else if(window.currentMode === 'arcade') { 
                    window.showView('arcade-view');
                    document.getElementById('arcade-intro').classList.remove('hidden');
                    document.getElementById('arcade-game').classList.add('hidden');
                    document.getElementById('arcade-result').classList.add('hidden');
                    
                    let targetText = window.arcadeTarget || 'current';
                    if(targetText === 'current') targetText = '현재 필터';
                    else if(targetText === 'all') targetText = '전체';
                    else if(targetText === 'studied') targetText = '학습완료';
                    else if(targetText === 'incorrect') targetText = '오답노트';
                    else if(targetText.startsWith('level-')) targetText = targetText.replace('level-', '');
                    else if(targetText.startsWith('type-')) targetText = targetText.replace('type-', '유형 ');
                    
                    const tl = document.getElementById('arcade-target-level');
                    if(tl) tl.textContent = targetText;
                }
                else if(window.currentMode === 'type') { window.renderTypePage(0); window.showView('type-learning-view'); }
                else if(window.currentMode === 'wordbook') { window.renderWordbook(); window.showView('wordbook-view'); }
                else if(window.currentMode === 'news-link') { window.showView('news-link-view'); }
                else if(window.currentMode === 'scan') { window.showView('scan-view'); }
                else { 
                    document.getElementById('bottom-controls').classList.remove('hidden');
                    if (window.currentMode === 'write') {
                        document.getElementById('bottom-controls').classList.add('hidden');
                    }
                    window.showView('main-view'); window.resetCardView(window.updateAllCards); 
                }
                window.toggleSidebar(); 
            });

            document.getElementById('sidebar-level-selector').addEventListener('click', e => {
                const btn = e.target.closest('button');
                if (btn && btn.dataset.level) {
                    window.filterCards(btn.dataset.level);
                }
            });

            document.getElementById('prev-btn').onclick = () => { window.triggerHaptic('tap'); window.animateCardChange(-1); };
            document.getElementById('next-btn').onclick = () => { window.triggerHaptic('tap'); window.animateCardChange(1); };

            const newsAnalyzeBtn = document.getElementById('analyze-btn');
            if(newsAnalyzeBtn) {
                newsAnalyzeBtn.onclick = async () => {
                    window.triggerHaptic('tap');
                    try {
                        const text = await navigator.clipboard.readText();
                        if (text && text.trim().length > 0) {
                            await window.processNewsText(text); 
                        } else {
                            throw new Error("Empty");
                        }
                    } catch (e) {
                        const modal = document.getElementById('news-modal-overlay');
                        if(modal) {
                            modal.classList.remove('hidden');
                            modal.classList.add('flex');
                        }
                        const pasteArea = document.getElementById('news-paste-area');
                        if(pasteArea) pasteArea.value = '';
                    }
                };
            }

            const newsConfirmBtn = document.getElementById('news-analyze-confirm-btn');
            if(newsConfirmBtn) {
                newsConfirmBtn.onclick = async () => {
                    window.triggerHaptic('tap');
                    const text = document.getElementById('news-paste-area').value;
                    if(text && text.trim().length > 0) {
                        await window.processNewsText(text);
                    } else {
                        window.showModal("붙여넣은 텍스트가 없습니다.");
                    }
                };
            }

            const cameraInput = document.getElementById('camera-input');
            if(cameraInput) {
                cameraInput.addEventListener('change', async (e) => {
                    const file = e.target.files[0];
                    if(!file) return;
                    const reader = new FileReader();
                    reader.onload = async (event) => {
                        document.getElementById('scan-preview').src = event.target.result;
                        document.getElementById('scan-preview').classList.remove('hidden');
                        document.getElementById('scan-analyze-btn').classList.remove('hidden');
                    };
                    reader.readAsDataURL(file);
                });
            }

            const analyzeBtn = document.getElementById('scan-analyze-btn');
            if(analyzeBtn) {
                analyzeBtn.onclick = async () => {
                    const img = document.getElementById('scan-preview').src;
                    if (!img || img === '') return;
                    window.triggerHaptic('tap');
                    
                    const base64 = img.split(',')[1];

                    document.getElementById('scan-loader').classList.remove('hidden');
                    document.getElementById('scan-analyze-btn').disabled = true;

                    const prompt = `이 이미지에서 한자(단어)를 모두 추출하고, 각 한자 단어의 한국어 독음을 분석하여 순수한 JSON 객체 형식으로만 답변해. 키는 한자 단어, 값은 한글 독음. 예시: {"學校":"학생"}. 절대 다른 텍스트나 설명은 포함하지 마. 한자가 없으면 빈 객체 {}를 반환해.`;

                    try {
                        const res = await callGeminiAPI(prompt, true, base64);
                        document.getElementById('scan-loader').classList.add('hidden');
                        document.getElementById('scan-analyze-btn').disabled = false;
                        
                        if (!res) throw new Error("API No Response");
                        
                        let pronunciations = {};
                        try {
                            const clean = extractJSON(res);
                            pronunciations = JSON.parse(clean);
                        } catch (parseErr) {
                            const regex = /"([\u4e00-\u9fa5\uF900-\uFAFF]+)"\s*:\s*"([가-힣]+)"/g;
                            let match;
                            while ((match = regex.exec(res)) !== null) {
                                pronunciations[match[1]] = match[2];
                            }
                            if (Object.keys(pronunciations).length === 0) {
                                throw new Error("데이터 파싱 완전 실패");
                            }
                        }

                        if(Object.keys(pronunciations).length === 0) {
                            window.showModal("이미지에서 한자를 찾을 수 없습니다.");
                            return;
                        }

                        Object.keys(pronunciations).forEach(w => window.userWordbook.set(w, pronunciations[w]));

                        if (window.userId) {
                            await setDoc(getUserDocRef(window.userId), { userWordbook: Object.fromEntries(window.userWordbook) }, { merge: true });
                        }

                        window.currentMode = 'wordbook';
                        window.updateTopTitle();
                        document.querySelectorAll('#sidebar-mode-selector button').forEach(b => b.classList.remove('active', 'text-accent-cyan-dark'));
                        const wbBtn = document.querySelector('#sidebar-mode-selector button[data-mode="wordbook"]');
                        if(wbBtn) wbBtn.classList.add('active', 'text-accent-cyan-dark');

                        window.renderWordbook();
                        window.showView('wordbook-view');
                        window.showModal(`${Object.keys(pronunciations).length}개의 한자 단어를 단어장에 저장했습니다!`);
                    } catch(e) {
                        document.getElementById('scan-loader').classList.add('hidden');
                        document.getElementById('scan-analyze-btn').disabled = false;
                        window.showModal(`분석에 실패했습니다. 이미지가 흐리거나 한자가 없는지 확인해주세요.<br><span class='text-[10px] text-gray-400 mt-2 block'>오류: ${e.message}</span>`);
                    }
                };
            }

            let startX = 0, startY = 0;
            let isDragging = false;
            let isScrolling = false;
            let preventClick = false; 
            
            const touchArea = document.getElementById('card-touch-area');

            const getX = (e) => e.type.includes('mouse') ? e.clientX : e.touches[0].clientX;
            const getY = (e) => e.type.includes('mouse') ? e.clientY : e.touches[0].clientY;

            const startDrag = (e) => {
                if (!window.cards || !window.cards.current) return;
                if(e.target.closest('button, canvas, a, .info-badge, .ai-feature-btn, .partner-btn, .timer-preset, .global-timer-pill, .radical-btn')) return;
                
                startX = getX(e);
                startY = getY(e);
                isDragging = true;
                isScrolling = false;
                preventClick = false; 
                window.totalMoveDistance = 0;
                
                window.cards.current.style.transition = 'none';
                if(window.cards.next) window.cards.next.style.transition = 'none';
                if(window.cards.prev) window.cards.prev.style.transition = 'none';
            };

            const moveDrag = (e) => {
                if(!isDragging) return;
                if (!window.cards || !window.cards.current) return;
                
                const currentX = getX(e);
                const currentY = getY(e);
                const dx = currentX - startX;
                const dy = currentY - startY;

                window.totalMoveDistance = Math.max(window.totalMoveDistance, Math.abs(dx), Math.abs(dy));

                if (!isScrolling && window.totalMoveDistance > 10) {
                    preventClick = true; 
                    
                    if (Math.abs(dy) > Math.abs(dx)) {
                        isScrolling = true;
                        isDragging = false;
                        window.cards.current.style.transform = ''; 
                        return;
                    }
                }

                if (isDragging && !isScrolling && window.totalMoveDistance > 10) {
                    if (e.cancelable) e.preventDefault(); 

                    const direction = dx < 0 ? 1 : -1; 
                    const targetCard = direction === 1 ? window.cards.next : window.cards.prev;
                    const hideCard = direction === 1 ? window.cards.prev : window.cards.next;
                    
                    if(targetCard) targetCard.style.display = 'block';
                    if(hideCard) hideCard.style.display = 'none';

                    const progress = Math.min(Math.abs(dx) / window.innerWidth, 1);
                    
                    window.cards.current.style.transformOrigin = 'center center';
                    window.cards.current.style.transform = `translateX(${dx}px)`;
                    if(targetCard) targetCard.style.transform = `scale(${0.95 + 0.05 * progress})`;
                }
            };

            const endDrag = (e) => {
                if (!window.cards || !window.cards.current) return;
                if(!isDragging && !isScrolling) return; 
                
                if (isDragging && !isScrolling && window.totalMoveDistance > 10) {
                    const endX = e.type.includes('mouse') ? e.clientX : (e.changedTouches ? e.changedTouches[0].clientX : startX);
                    const dx = endX - startX;
                    
                    if (Math.abs(dx) > 60) {
                        window.animateCardChange(dx < 0 ? 1 : -1);
                    } else {
                        window.cards.current.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1)';
                        window.cards.current.style.transform = '';
                        if(window.cards.next) {
                            window.cards.next.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1)';
                            window.cards.next.style.transform = 'scale(0.95)';
                        }
                        if(window.cards.prev) {
                            window.cards.prev.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1)';
                            window.cards.prev.style.transform = 'scale(0.95)';
                        }
                    }
                } else {
                    window.cards.current.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1)';
                    preventClick = false; 
                }
                
                isDragging = false;
                isScrolling = false;
                startX = 0;
                startY = 0;
            };

            touchArea.addEventListener('mousedown', startDrag); 
            window.addEventListener('mousemove', moveDrag, {passive: false}); 
            window.addEventListener('mouseup', endDrag);
            touchArea.addEventListener('touchstart', startDrag, {passive: true}); 
            window.addEventListener('touchmove', moveDrag, {passive: false}); 
            window.addEventListener('touchend', endDrag);

            touchArea.addEventListener('click', (e) => {
                if (!window.cards || !window.cards.current) return;
                if(e.target.closest('button, canvas, a, .info-badge, .ai-feature-btn, .global-timer-pill, .radical-btn')) return;
                if (preventClick) { preventClick = false; return; }
                if (window.currentMode === 'write') return; 
                window.flipCard();
            });
        }

        window.renderHanjaWriter = async function(targetId, char, size = 220) {
            const target = document.getElementById(targetId);
            if(!target) return; 
            
            const strokeColor = window.isDarkMode ? '#e2e8f0' : '#2d2d2d';
            const fontSize = Math.floor(size * 0.7);
            
            target.innerHTML = `
                <div id="${targetId}-text" class="absolute inset-0 flex justify-center items-center hanja-font text-text-main" style="font-size: ${fontSize}px; transition: opacity 0.5s ease; z-index: 1;">${char}</div>
                <div id="${targetId}-svg" class="absolute inset-0 flex justify-center items-center z-10 pointer-events-none"></div>
            `;
            
            try {
                const res = await fetch(`https://cdn.jsdelivr.net/npm/hanzi-writer-data@2.0/${char}.json`);
                if (!res.ok) return; 
                
                const charData = await res.json();
                
                HanziWriter.create(`${targetId}-svg`, char, { 
                    width: size, height: size, padding: size * 0.05, showCharacter: true, strokeColor: strokeColor,
                    charDataLoader: function(c, onComplete) { onComplete(charData); }
                });
                
                const textEl = document.getElementById(`${targetId}-text`);
                if(textEl) textEl.style.opacity = '0';
            } catch(e) {}
        }

        window.formatPartner = function(str) {
            if(!str) return '';
            const hanjas = str.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g);
            if (!hanjas) return `<span class="text-xs text-gray-600">${str}</span>`;
            return [...new Set(hanjas)].map(s => {
                let hText = '';
                const hData = window.hanjaMap.get(s);
                if(hData) hText = hData.huneum;
                return `<div class="inline-flex items-center gap-1.5 mr-2 mb-1.5 cursor-pointer active:scale-95 transition-transform" onclick="window.showDetailFromPolysemy(${hData ? hData.no : 0})">
                            <div class="w-[32px] h-[32px] flex-shrink-0 bg-white border border-[#dfd6c2] rounded shadow-sm hanja-font text-lg font-bold text-text-main flex items-center justify-center">${s}</div>
                            <span class="text-[10px] font-bold text-gray-500 tracking-tighter leading-tight whitespace-nowrap">${hText}</span>
                        </div>`;
            }).join('');
        };

        window.showRadicalTree = function(char) {
            window.triggerHaptic('tap');
            const family = window.hanjaData.filter(h => h.hanja !== char && (h.hanja.includes(char) || (h.paja && h.paja.includes(char))));
            
            document.getElementById('radical-modal-title').innerHTML = `<span class="hanja-font text-xl mr-1">${char}</span> 부수 계보도`;
            let html = '';
            if(family.length === 0) {
                html = `<p class="text-sm text-gray-500 text-center py-6 font-bold">이 부수를 사용하는 다른 한자가<br>아직 데이터에 없습니다.</p>`;
            } else {
                html = family.map(h => `
                    <div class="bg-white p-3 rounded-xl border border-gray-200 shadow-sm flex items-center gap-3 cursor-pointer active:scale-95 transition-transform" onclick="window.showDetailFromPolysemy(${h.no})">
                        <div class="w-12 h-12 flex-shrink-0 bg-blue-50 text-blue-700 hanja-font text-2xl flex justify-center items-center rounded-lg border border-blue-100">${h.hanja}</div>
                        <div class="flex-1 min-w-0 text-left">
                            <div class="font-bold text-gray-800 text-[14px] truncate">${h.huneum}</div>
                            <div class="text-[10px] font-bold text-gray-400 mt-0.5 truncate">${h.paja || h.level}</div>
                        </div>
                    </div>
                `).join('');
            }
            document.getElementById('radical-modal-content').innerHTML = html;
            document.getElementById('radical-modal-overlay').classList.remove('hidden');
            document.getElementById('radical-modal-overlay').classList.add('flex');
        };

        window.getBackCardContent = function(data, canvasId, targetId, backHeaderId, isWriteMode = false) {
            
            const explainColors = ['text-blue-600', 'text-purple-600', 'text-teal-600', 'text-rose-600', 'text-amber-600'];
            let explainColorIdx = 0;
            const highlightGeneralHanja = (txt) => {
                if(!txt) return '';
                return txt.replace(/([\u4e00-\u9fa5\uF900-\uFAFF]+)/g, (match) => {
                    const cClass = explainColors[explainColorIdx % explainColors.length];
                    explainColorIdx++;
                    return `<span class="hanja-font text-[1.35rem] ${cClass} font-bold mx-0.5 drop-shadow-sm align-bottom">${match}</span>`;
                });
            };

            const highlightedExplanation = highlightGeneralHanja(data.explanation);
            const explanation = highlightedExplanation ? `<div class="bg-white/70 p-4 rounded-xl border border-[#dfd6c2] mb-3"><h3 class="mb-1.5 text-accent-cyan-dark font-bold text-[12px] uppercase">📖 해설</h3><p class="text-[15px] leading-relaxed text-gray-800 break-keep">${highlightedExplanation}</p></div>` : '';
            
            const colorClasses = ['text-red-600', 'text-blue-600', 'text-amber-600', 'text-emerald-600', 'text-purple-600'];
            const pajaHanjas = data.paja ? [...new Set(data.paja.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g) || [])].filter(c => c !== data.hanja) : [];
            
            let pajaVisual = '';
            let coloredPaja = data.paja || '';
            let coloredAmgi = data.amgi || '';

            if (pajaHanjas.length > 0) {
                let visualParts = [];
                pajaHanjas.forEach((char, idx) => {
                    const cClass = colorClasses[idx % colorClasses.length];
                    visualParts.push(`<span class="radical-btn hanja-font ${cClass} text-3xl drop-shadow-sm leading-none cursor-pointer hover:scale-110 active:scale-95 transition-transform inline-block px-1" onclick="window.showRadicalTree('${char}'); event.stopPropagation();" title="같은 부수 보기">${char}</span>`);
                    
                    const regex = new RegExp(char, 'g');
                    const replacement = `<span class="hanja-font ${cClass} text-[1.4rem] font-bold mx-0.5 drop-shadow-sm align-bottom">${char}</span>`;
                    coloredPaja = coloredPaja.replace(regex, replacement);
                    coloredAmgi = coloredAmgi.replace(regex, replacement);
                });
                
                pajaVisual = `<div class="flex items-center justify-center gap-1.5 mt-1 mb-4 bg-white/60 py-2 px-5 rounded-full border border-[#dfd6c2] shadow-sm w-max mx-auto">
                    <span class="text-[10px] font-bold text-accent-cyan-dark mr-1 uppercase tracking-widest bg-accent-cyan/10 px-1.5 py-0.5 rounded">터치하여 가족 찾기</span>
                    ${visualParts.join('<span class="text-gray-300 text-lg font-bold px-1">+</span>')}
                </div>`;
            } else {
                const amgiHanjas = data.amgi ? [...new Set(data.amgi.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g) || [])] : [];
                amgiHanjas.forEach((char) => {
                    const regex = new RegExp(char, 'g');
                    const replacement = `<span class="hanja-font text-red-600 text-[1.4rem] font-bold mx-0.5 drop-shadow-sm align-bottom">${char}</span>`;
                    coloredAmgi = coloredAmgi.replace(regex, replacement);
                });
            }

            const amgiCombined = [coloredPaja, coloredAmgi].filter(Boolean).join('<br><br>');
            const amgi = amgiCombined ? `<div class="bg-white/70 p-4 rounded-xl border border-[#dfd6c2] mb-3"><h3 class="mb-3 text-accent-cyan-dark font-bold text-[12px] uppercase">💡 암기 요령 (파자)</h3><p class="text-[15px] text-gray-800 leading-relaxed break-keep">${amgiCombined}</p></div>` : '';
            
            let corner = '';
            if(data.similarHanja) corner += `<div class="flex items-start mb-1.5"><span class="text-[10px] text-gray-400 w-11 font-bold flex-shrink-0 mt-1.5">비슷한</span><div class="flex flex-wrap flex-1">${window.formatPartner(data.similarHanja)}</div></div>`;
            if(data.synonyms) corner += `<div class="flex items-start mb-1.5"><span class="text-[10px] text-gray-400 w-11 font-bold flex-shrink-0 mt-1.5">유의어</span><div class="flex flex-wrap flex-1">${window.formatPartner(data.synonyms)}</div></div>`;
            if(data.antonyms) corner += `<div class="flex items-start mb-1.5"><span class="text-[10px] text-gray-400 w-11 font-bold flex-shrink-0 mt-1.5">반의어</span><div class="flex flex-wrap flex-1">${window.formatPartner(data.antonyms)}</div></div>`;
            if(data.textbookWords) corner += `<div class="bg-[#eaf4f4] p-3 rounded-lg mt-2 mb-1 shadow-sm"><span class="text-[10px] text-accent-cyan-dark font-bold uppercase block mb-1.5">교재단어</span><span class="font-bold text-xl text-text-main hanja-font tracking-wide break-keep leading-tight">${data.textbookWords}</span></div>`;

            const hanjaCorner = corner ? `<div class="bg-white/70 p-4 rounded-xl border border-[#dfd6c2] mb-3"><h3 class="mb-3 text-accent-cyan-dark font-bold text-[12px] uppercase">🧩 한자 짝꿍</h3>${corner}</div>` : '';

            // --- 음표(발음 가족) 계보도 동적 생성 알고리즘 ---
            const getSounds = (huneumStr) => {
                if(!huneumStr) return [];
                return huneumStr.split(/[,|/]/).map(part => {
                    let t = part.replace(/\(.*?\)/g, '').replace(/[^가-힣\s]/g, '').trim();
                    const parts = t.split(/\s+/);
                    const lastPart = parts[parts.length - 1];
                    return lastPart ? lastPart.charAt(lastPart.length - 1) : '';
                }).filter(Boolean);
            };
            
            const currentSounds = getSounds(data.huneum);
            const currentComponents = new Set([data.hanja, ...(data.paja ? data.paja.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g) || [] : [])]);

            let phoneticFamily = [];
            window.hanjaData.forEach(h => {
                if (h.no === data.no) return;
                const hSounds = getSounds(h.huneum);
                const hasSameSound = currentSounds.some(s => hSounds.includes(s));
                
                if (hasSameSound) {
                    const hComponents = new Set([h.hanja, ...(h.paja ? h.paja.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g) || [] : [])]);
                    const sharesComponent = [...currentComponents].some(c => hComponents.has(c));
                    if (sharesComponent) {
                        phoneticFamily.push(h);
                    }
                }
            });

            let phoneticVisual = '';
            if (phoneticFamily.length > 0) {
                const familyHTML = phoneticFamily.slice(0, 8).map(h => {
                    return `<div class="inline-flex items-center gap-1.5 mr-2 mb-1.5 cursor-pointer active:scale-95 transition-transform" onclick="window.showDetailFromPolysemy(${h.no})">
                                <div class="w-[32px] h-[32px] flex-shrink-0 bg-yellow-50 border border-yellow-200 rounded shadow-sm hanja-font text-lg font-bold text-yellow-800 flex items-center justify-center">${h.hanja}</div>
                                <span class="text-[10px] font-bold text-gray-600 tracking-tighter leading-tight whitespace-nowrap">${h.huneum}</span>
                            </div>`;
                }).join('');
                
                phoneticVisual = `<div class="bg-white/70 p-4 rounded-xl border border-[#dfd6c2] mb-3 shadow-sm">
                                    <h3 class="mb-3 text-accent-cyan-dark font-bold text-[12px] uppercase">🗣️ 발음 가족 (음표 계보도)</h3>
                                    <div class="flex items-start mb-1.5">
                                        <div class="flex flex-wrap flex-1">${familyHTML}</div>
                                    </div>
                                  </div>`;
            }
            // ------------------------------------

            const aiHelper = `
                <div class="bg-white/70 p-4 rounded-xl border border-[#dfd6c2] mb-3">
                    <h3 class="mb-3 text-accent-cyan-dark font-bold text-[12px] uppercase">🤖 AI 학습 도우미</h3>
                    <div class="space-y-2">
                        <div>
                            <button class="btn-neumorphic w-full py-2 text-xs font-bold" data-hanja="${data.hanja}" data-huneum="${data.huneum}" onclick="window.generateStory(this, 'story'); event.stopPropagation();">🧠 연상 암기법 생성</button>
                            <div class="ai-content hidden mt-2 p-3 rounded border border-gray-200 bg-white/50"><div class="ai-loader text-center text-accent-cyan text-[10px] font-bold hidden">생성 중...</div><div class="ai-text text-sm leading-relaxed text-gray-700"></div></div>
                        </div>
                        <div>
                            <button class="btn-neumorphic w-full py-2 text-xs font-bold text-purple-600" data-hanja="${data.hanja}" data-huneum="${data.huneum}" onclick="window.generateStory(this, 'idiom'); event.stopPropagation();">📜 사자성어 / 활용 문장 생성</button>
                            <div class="ai-content hidden mt-2 p-3 rounded border border-gray-200 bg-white/50"><div class="ai-loader text-center text-accent-cyan text-[10px] font-bold hidden">생성 중...</div><div class="ai-text text-sm leading-relaxed text-gray-700 w-full"></div></div>
                        </div>
                        <div>
                            <button class="btn-neumorphic w-full py-2 text-xs font-bold text-emerald-600" data-hanja="${data.hanja}" data-huneum="${data.huneum}" onclick="window.generateEtymology(this, '${backHeaderId}'); event.stopPropagation();">📜 어원 변천사 (갑골문) 애니메이션</button>
                            <div class="ai-content hidden mt-2 p-3 rounded border border-gray-200 bg-white/50"><div class="ai-loader text-center text-accent-cyan text-[10px] font-bold hidden">어원 추적 중...</div><div class="ai-text text-sm leading-relaxed text-gray-700 w-full"></div></div>
                        </div>
                    </div>
                </div>`;

            let writeSection = '';
            if (isWriteMode) {
                writeSection = `
                <div class="bg-white/70 p-3 rounded-xl border border-[#dfd6c2] mt-3 mb-3 text-center shadow-sm">
                    <button onclick="window.flipCard(); event.stopPropagation();" class="btn-neumorphic w-full py-3.5 text-[14px] font-bold text-accent-cyan-dark">🔙 쓰기 화면으로 복귀</button>
                </div>`;
            } else {
                writeSection = `
                <div class="bg-white/70 p-4 rounded-xl border border-[#dfd6c2] mt-3 mb-3 text-center">
                    <h3 class="mb-3 text-accent-cyan-dark font-bold text-[12px] text-left uppercase">✍️ 써보기</h3>
                    <div class="relative w-[180px] h-[180px] sm:w-[200px] sm:h-[200px] mx-auto mb-4 flex justify-center items-center flex-shrink-0 border-2 border-[var(--grid-color)] rounded-xl shadow-inner canvas-grid overflow-hidden">
                        <div id="${targetId}" class="absolute inset-0 w-full h-full pointer-events-none flex justify-center items-center z-10"></div>
                        <canvas id="${canvasId}" class="absolute inset-0 w-full h-full z-20 touch-none block" style="background: transparent;"></canvas>
                    </div>
                    <div class="grid grid-cols-2 gap-2">
                        <button onclick="window.initCanvas('${canvasId}', true); event.stopPropagation();" class="btn-neumorphic text-xs py-2 font-bold">지우기</button>
                        <button onclick="window.animateAnswer('${data.hanja}', '${targetId}'); event.stopPropagation();" class="btn-neumorphic text-xs py-2 font-bold text-accent-cyan-dark">정답확인</button>
                    </div>
                </div>`;
            }

            return `<div class="w-full h-full overflow-y-auto px-4 py-8 text-left no-scrollbar">
                <div class="text-center mb-4 mt-2 flex-shrink-0 flex flex-col items-center justify-center relative">
                    <div class="flex items-center justify-center gap-4 mb-2">
                        <div id="${backHeaderId}" class="relative w-[88px] h-[88px] flex items-center justify-center flex-shrink-0 drop-shadow-md">
                            <div id="${backHeaderId}-emoji" class="absolute inset-0 flex items-center justify-center text-[4rem] opacity-0 pointer-events-none z-20"></div>
                        </div>
                        <div class="flex flex-col items-start gap-1">
                            <span class="font-bold text-2xl text-accent-cyan-dark tracking-wide drop-shadow-sm">${data.huneum}</span>
                        </div>
                    </div>
                    ${pajaVisual}
                </div>
                <div class="flex-1">${explanation} ${amgi} ${hanjaCorner} ${phoneticVisual} ${aiHelper} ${writeSection}</div>
            </div>`;
        };

        window.getWriteViewHTML = function(data, canvasId, targetId) {
            return `<div class="w-full h-full flex flex-col justify-between items-center py-2 px-2">
                <div class="flex-shrink-0 text-center w-full mt-2 relative">
                    <span class="text-[10px] text-accent-cyan-dark font-bold uppercase tracking-widest bg-accent-cyan/10 px-2 py-0.5 rounded-full border border-accent-cyan/20">뜻과 소리</span>
                    <div class="font-bold text-3xl text-text-main mt-3 drop-shadow-sm flex items-center justify-center gap-3">
                        ${data.huneum}
                    </div>
                    <div class="text-[10px] text-gray-400 mt-2 font-bold">아래 캔버스에 한자를 적어보세요</div>
                </div>
                
                <div class="flex-shrink-0 relative w-[180px] h-[180px] sm:w-[200px] sm:h-[200px] mx-auto my-auto border-2 border-[var(--grid-color)] rounded-xl shadow-inner canvas-grid overflow-hidden">
                    <div id="${targetId}" class="absolute inset-0 w-full h-full pointer-events-none flex justify-center items-center z-10"></div>
                    <canvas id="${canvasId}" class="absolute inset-0 w-full h-full z-20 touch-none block" style="background: transparent;"></canvas>
                </div>
                
                <div class="w-full flex flex-col gap-2 flex-shrink-0 px-1 mb-1">
                    <div class="w-full flex gap-2">
                        <button onclick="window.initCanvas('${canvasId}', true); event.stopPropagation();" class="flex-1 btn-neumorphic py-3 text-[13px] font-bold shadow-sm">지우기</button>
                        <button onclick="window.animateAnswer('${data.hanja}', '${targetId}'); event.stopPropagation();" class="flex-1 btn-neumorphic py-3 text-[13px] font-bold text-accent-cyan-dark shadow-sm tracking-widest">정답확인</button>
                    </div>
                    <button onclick="window.flipCard(); event.stopPropagation();" class="w-full btn-neumorphic py-2.5 text-[12px] font-bold text-purple-600 shadow-sm mt-1">📖 해설 및 암기요령 보기</button>
                </div>
            </div>`;
        }

        window.updateCardContent = function(cardEl, index) {
            if (!cardEl) return;
            if (window.filteredHanjaData.length === 0) return;
            const data = window.filteredHanjaData[index];
            if (!data) return;
            
            if (cardEl.dataset.index == index && cardEl.dataset.mode == window.currentMode) return;
            cardEl.dataset.index = index;
            cardEl.dataset.mode = window.currentMode;
            
            const frontEl = cardEl.querySelector('.card-front');
            const backEl = cardEl.querySelector('.card-back');
            
            const badges = `<div class="info-badge-container z-10">
                <span class="info-badge">${data.level}</span>
                <button class="info-badge text-gray-500">유형 ${data.typeNo}</button>
            </div>`;
            
            const writerId = cardEl.id + '-writer'; 
            const canvasId = cardEl.id + '-canvas'; 
            const targetId = cardEl.id + '-target'; 
            const backHeaderId = cardEl.id + '-back-header';

            if (window.currentMode === 'read') {
                frontEl.innerHTML = badges + `<div id="${writerId}" class="w-full h-full relative flex justify-center items-center p-0"></div>`;
                window.renderHanjaWriter(writerId, data.hanja, 220);
                backEl.innerHTML = window.getBackCardContent(data, canvasId, targetId, backHeaderId, false);
                window.renderHanjaWriter(backHeaderId, data.hanja, 88);
            } else {
                frontEl.innerHTML = badges + window.getWriteViewHTML(data, canvasId, targetId);
                backEl.innerHTML = window.getBackCardContent(data, canvasId + '-back', targetId + '-back', backHeaderId, true);
                window.renderHanjaWriter(backHeaderId, data.hanja, 88);
                
                setTimeout(() => {
                    window.initCanvas(canvasId);
                }, 50);
            }
        };

        window.updateAllCards = function() {
            if (!window.cards || !window.cards.current) return;
            const len = window.filteredHanjaData.length;
            if (len === 0) {
                window.cards.current.querySelector('.card-front').innerHTML = `<div class="w-full h-full flex items-center justify-center text-sm text-gray-400 font-bold">조건에 맞는 한자가 없습니다.</div>`;
                window.cards.current.querySelector('.card-back').innerHTML = `<div class="w-full h-full flex items-center justify-center text-sm text-gray-400 font-bold">조건에 맞는 한자가 없습니다.</div>`;
                if(DOM.progress) DOM.progress.textContent = '0 / 0';
                return;
            }
            
            const curIdx = window.currentIndex;
            const prevIdx = (curIdx - 1 + len) % len;
            const nextIdx = (curIdx + 1) % len;
            
            window.updateCardContent(window.cards.current, curIdx);
            if (len > 1) {
                window.updateCardContent(window.cards.prev, prevIdx);
                window.updateCardContent(window.cards.next, nextIdx);
            }
            
            if(DOM.progress) DOM.progress.textContent = `${curIdx + 1} / ${len}`;
        };

        window.flipCard = function() {
            if(window.filteredHanjaData.length === 0) return;
            if(!window.cards || !window.cards.current) return;
            
            window.triggerHaptic('tap');
            
            window.isFlipped = !window.isFlipped;
            window.cards.current.querySelector('.card-inner').classList.toggle('is-flipped');
            
            const checkContainer = document.getElementById('check-toggle-container');
            
            if(window.isFlipped) {
                if(checkContainer && window.currentMode !== 'write') checkContainer.classList.remove('invisible', 'opacity-0');
                if(DOM.progress) DOM.progress.classList.add('opacity-0');
                
                const canvasId = window.currentMode === 'write' ? window.cards.current.id + '-canvas-back' : window.cards.current.id + '-canvas';
                setTimeout(() => window.initCanvas(canvasId), 350);
                
            } else {
                if(checkContainer) {
                    checkContainer.classList.add('opacity-0');
                    setTimeout(() => { if(!window.isFlipped) checkContainer.classList.add('invisible'); }, 200);
                }
                if(DOM.progress) DOM.progress.classList.remove('opacity-0');
            }
        };

        window.animateCardChange = function(direction) {
            if (window.filteredHanjaData.length === 0) return;
            if (window.isAnimating) return; 
            if (!window.cards || !window.cards.current) return;
            window.isAnimating = true;
            
            const throwX = direction === 1 ? -window.innerWidth * 1.5 : window.innerWidth * 1.5;
            
            window.cards.current.style.transformOrigin = 'center center';
            window.cards.current.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1), opacity 0.3s ease-out';
            window.cards.current.style.transform = `translateX(${throwX}px)`;
            window.cards.current.style.opacity = '0';
            
            const targetCard = direction === 1 ? window.cards.next : window.cards.prev;
            targetCard.style.display = 'block';
            targetCard.style.transition = 'transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1)';
            targetCard.style.transform = 'scale(1)';

            setTimeout(() => {
                const len = window.filteredHanjaData.length;
                window.currentIndex = (window.currentIndex + direction + len) % len;
                if (window.isAppInitialized) window.savePositionToFirebase();
                
                const oldCurrent = window.cards.current;
                if (direction === 1) {
                    window.cards.current = window.cards.next;
                    window.cards.next = window.cards.prev; 
                    window.cards.prev = oldCurrent;
                } else {
                    window.cards.current = window.cards.prev;
                    window.cards.prev = window.cards.next;
                    window.cards.next = oldCurrent;
                }
                
                window.isFlipped = false;
                window.cards.current.querySelector('.card-inner').classList.remove('is-flipped');
                window.cards.next.querySelector('.card-inner').classList.remove('is-flipped');
                window.cards.prev.querySelector('.card-inner').classList.remove('is-flipped');
                
                const checkContainer = document.getElementById('check-toggle-container');
                if(checkContainer) checkContainer.classList.add('invisible', 'opacity-0');
                if(DOM.progress) DOM.progress.classList.remove('opacity-0');
                
                window.cards.current.style.transition = 'none';
                window.cards.current.style.transform = 'translateX(0) scale(1)'; 
                window.cards.current.style.opacity = '1';
                window.cards.current.style.zIndex = '10';
                window.cards.current.style.display = 'block';
                window.cards.current.style.pointerEvents = 'auto';
                
                window.cards.next.style.transition = 'none';
                window.cards.next.style.transform = 'scale(0.95)';
                window.cards.next.style.zIndex = '0';
                window.cards.next.style.display = 'none'; 
                window.cards.next.style.opacity = '1';
                window.cards.next.style.pointerEvents = 'none';
                
                window.cards.prev.style.transition = 'none';
                window.cards.prev.style.transform = 'scale(0.95)';
                window.cards.prev.style.zIndex = '0';
                window.cards.prev.style.display = 'none'; 
                window.cards.prev.style.opacity = '1';
                window.cards.prev.style.pointerEvents = 'none';

                window.updateAllCards();
                window.isAnimating = false;

            }, 400); 
        };

        window.savePositionToFirebase = async function() {
            if (!window.userId || window.filteredHanjaData.length === 0 || !window.isAppInitialized) return;
            window.savedIndices[window.currentLevel] = window.currentIndex;
            try { 
                await setDoc(getUserDocRef(window.userId), { 
                    lastLevel: window.currentLevel, 
                    savedIndices: window.savedIndices,
                    activityLog: window.activityLog,
                    isDarkMode: window.isDarkMode
                }, { merge: true }); 
            } catch(e) {}
        };

        window.buildSmartDeck = function() {
            let poolIncorrect = window.hanjaData.filter(h => window.incorrectAnswers.has(h.no));
            let poolUnmemorized = window.hanjaData.filter(h => !window.knownAnswers.has(h.no) && !window.incorrectAnswers.has(h.no));
            let poolKnown = window.hanjaData.filter(h => window.knownAnswers.has(h.no));

            poolIncorrect.sort(() => 0.5 - Math.random());
            poolUnmemorized.sort(() => 0.5 - Math.random());
            poolKnown.sort(() => 0.5 - Math.random());

            let deck = [...poolIncorrect.slice(0, 20), ...poolUnmemorized.slice(0, 10), ...poolKnown.slice(0, 5)];
            deck.sort(() => 0.5 - Math.random());
            if(deck.length === 0) return window.hanjaData.slice(0, 30);
            return deck;
        }

        window.applyFilterAndRestoreIndex = function(level, index) {
            window.currentLevel = level;
            window.updateTopTitle();
            
            document.querySelectorAll('#sidebar-level-selector button').forEach(b => {
                if(b.dataset.level === level) {
                    b.classList.add('ring-2', 'ring-accent-cyan', 'text-accent-cyan-dark');
                    b.classList.remove('text-gray-600', 'border-gray-200');
                } else {
                    b.classList.remove('ring-2', 'ring-accent-cyan', 'text-accent-cyan-dark');
                    if(!b.classList.contains('text-red-700') && !b.classList.contains('text-green-700') && !b.classList.contains('text-blue-700')) {
                        b.classList.add('text-gray-600');
                    }
                    b.classList.add('border-gray-200');
                }
            });
            
            if (level === '스마트') window.filteredHanjaData = window.buildSmartDeck();
            else if (level === '전체') window.filteredHanjaData = [...window.hanjaData];
            else if (level === '암기') window.filteredHanjaData = window.hanjaData.filter(h => window.knownAnswers.has(h.no));
            else if (level === '미암기') window.filteredHanjaData = window.hanjaData.filter(h => window.incorrectAnswers.has(h.no));
            else window.filteredHanjaData = window.hanjaData.filter(h => h.level && h.level.includes(level));
            
            window.currentIndex = (index >= 0 && index < window.filteredHanjaData.length) ? index : 0;
            
            if (window.cards && window.cards.current) {
                window.resetCardView(window.updateAllCards);
            } else {
                document.addEventListener('DOMContentLoaded', () => {
                    bindCards();
                    window.resetCardView(window.updateAllCards);
                });
            }
        };

        window.filterCards = function(level) {
            window.triggerHaptic('tap');
            window.savedIndices[window.currentLevel] = window.currentIndex;
            window.savePositionToFirebase();
            const nextIndex = window.savedIndices[level] || 0;
            window.applyFilterAndRestoreIndex(level, nextIndex);
            window.toggleSidebar(); 
        };

        window.backupData = function() {
            window.triggerHaptic('tap');
            const backupObj = {
                knownAnswers: Array.from(window.knownAnswers),
                incorrectAnswers: Array.from(window.incorrectAnswers),
                userWordbook: Object.fromEntries(window.userWordbook),
                lastLevel: window.currentLevel,
                savedIndices: window.savedIndices,
                activityLog: window.activityLog,
                backupDate: new Date().toISOString()
            };
            const blob = new Blob([JSON.stringify(backupObj, null, 2)], { type: 'application/json' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            const dateStr = new Date().toLocaleDateString('ko-KR').replace(/\./g, '').replace(/ /g, '-');
            a.download = `hanja_backup_${dateStr}.json`;
            document.body.appendChild(a);
            a.click();
            setTimeout(() => {
                document.body.removeChild(a);
                URL.revokeObjectURL(url);
            }, 100);
            window.showModal("데이터 백업이 완료되었습니다.<br>(다운로드 폴더를 확인하세요)");
        };

        window.restoreData = function(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = async function(e) {
                try {
                    const contents = e.target.result;
                    const parsed = JSON.parse(contents);

                    if (!parsed.knownAnswers || !parsed.incorrectAnswers) throw new Error("Invalid format");

                    if (parsed.knownAnswers) window.knownAnswers = new Set(parsed.knownAnswers);
                    if (parsed.incorrectAnswers) window.incorrectAnswers = new Set(parsed.incorrectAnswers);
                    if (parsed.userWordbook) window.userWordbook = new Map(Object.entries(parsed.userWordbook));
                    if (parsed.savedIndices) window.savedIndices = parsed.savedIndices;
                    if (parsed.activityLog) window.activityLog = parsed.activityLog;
                    if (parsed.lastLevel) window.currentLevel = parsed.lastLevel;
                    
                    let restoreIdx = window.savedIndices[window.currentLevel] || 0;
                    if (parsed.lastIndex !== undefined && !parsed.savedIndices) restoreIdx = parsed.lastIndex; 

                    if (window.userId) {
                        await setDoc(getUserDocRef(window.userId), { 
                            knownAnswers: Array.from(window.knownAnswers),
                            incorrectAnswers: Array.from(window.incorrectAnswers),
                            userWordbook: Object.fromEntries(window.userWordbook),
                            lastLevel: window.currentLevel,
                            savedIndices: window.savedIndices,
                            activityLog: window.activityLog
                        }, { merge: true });
                    }

                    window.showModal("데이터가 성공적으로 복원되었습니다!");
                    window.updateGamificationUI();
                    
                    if (window.currentMode === 'wordbook') {
                        window.renderWordbook();
                    } else {
                        window.applyFilterAndRestoreIndex(window.currentLevel, restoreIdx);
                    }
                    window.updateTopTitle();
                    
                    const sidebar = document.getElementById('sidebar');
                    if (!sidebar.classList.contains('-translate-x-full')) window.toggleSidebar();

                } catch (err) { window.showModal("올바른 백업 파일 형식이 아닙니다."); }
            };
            reader.readAsText(file);
        };

        window.initCanvas = function(id, forceClear = false) {
            const c = document.getElementById(id); if(!c) return;
            const ctx = c.getContext('2d'), dpr = window.devicePixelRatio || 1;
            
            c.style.opacity = '1';

            const ensureSizeAndClear = () => {
                const rect = c.getBoundingClientRect();
                const w = rect.width > 0 ? rect.width : 160;
                const h = rect.height > 0 ? rect.height : 160;
                c.width = w * dpr; 
                c.height = h * dpr;
                ctx.scale(dpr, dpr); 
                ctx.lineWidth = 4; 
                ctx.lineCap = 'round'; 
                ctx.lineJoin = 'round'; 
                ctx.strokeStyle = window.isDarkMode ? '#e0e0e0' : '#2d2d2d';
                ctx.shadowBlur = 0;
            };

            if (forceClear) {
                ensureSizeAndClear();
                const targetId = id.replace('-canvas', '-target');
                const t = document.getElementById(targetId);
                if(t) t.innerHTML = ''; 
                return;
            }
            
            const rect = c.getBoundingClientRect();
            if(c.width === 0 || c.width === 300 || c.width !== Math.floor(rect.width * dpr)) {
                if(rect.width > 0) ensureSizeAndClear();
            }

            let dr = false;
            const getP = (e) => { 
                const rBox = c.getBoundingClientRect(); 
                const clientX = e.clientX || (e.touches && e.touches.length > 0 ? e.touches[0].clientX : 0);
                const clientY = e.clientY || (e.touches && e.touches.length > 0 ? e.touches[0].clientY : 0);
                
                const scaleX = (c.width / dpr) / rBox.width;
                const scaleY = (c.height / dpr) / rBox.height;
                
                return {
                    x: (clientX - rBox.left) * scaleX, 
                    y: (clientY - rBox.top) * scaleY
                }; 
            };
            
            c.onmousedown = (e) => { e.stopPropagation(); dr = true; ctx.beginPath(); const p = getP(e); ctx.moveTo(p.x, p.y); ctx.lineTo(p.x, p.y); ctx.stroke(); };
            c.onmousemove = (e) => { e.stopPropagation(); if(!dr) return; const p = getP(e); ctx.lineTo(p.x, p.y); ctx.stroke(); };
            c.onmouseup = (e) => { e.stopPropagation(); dr = false; };
            c.onmouseout = (e) => { dr = false; };
            
            c.ontouchstart = (e) => { e.preventDefault(); e.stopPropagation(); dr = true; ctx.beginPath(); const p = getP(e); ctx.moveTo(p.x, p.y); ctx.lineTo(p.x, p.y); ctx.stroke(); };
            c.ontouchmove = (e) => { e.preventDefault(); e.stopPropagation(); if(!dr) return; const p = getP(e); ctx.lineTo(p.x, p.y); ctx.stroke(); };
            c.ontouchend = (e) => { e.stopPropagation(); dr = false; };
        };

        window.animateAnswer = async function(char, targetId) {
            const target = document.getElementById(targetId);
            if (!target) return;
            target.innerHTML = '';
            
            const canvasId = targetId.replace('-target', '-canvas');
            const canvasEl = document.getElementById(canvasId);
            
            if (canvasEl) {
                canvasEl.style.transition = 'opacity 0.3s ease';
                canvasEl.style.opacity = '0.25';
            }
            
            const size = target.parentElement.clientWidth || 160; 
            const strokeColor = window.isDarkMode ? '#63b3ed' : '#2b6cb0';
            try {
                const res = await fetch(`https://cdn.jsdelivr.net/npm/hanzi-writer-data@2.0/${char}.json`);
                if (!res.ok) {
                    target.innerHTML = `<div class="w-full h-full flex justify-center items-center hanja-font text-accent-cyan-dark" style="font-size: ${size * 0.85}px; line-height: 1; color: ${strokeColor}">${char}</div>`;
                    return;
                }
                const charData = await res.json();
                const writer = HanziWriter.create(target, char, {
                    width: size, height: size, padding: size * 0.05, 
                    showCharacter: false, showOutline: false, strokeAnimationSpeed: 1.5, delayBetweenStrokes: 100, strokeColor: strokeColor,
                    charDataLoader: function(c, onComplete) { onComplete(charData); }
                });
                if (writer && typeof writer.animateCharacter === 'function') writer.animateCharacter().catch(e => {}); 
            } catch(e) {
                target.innerHTML = `<div class="w-full h-full flex justify-center items-center hanja-font text-accent-cyan-dark" style="font-size: ${size * 0.85}px; line-height: 1; color: ${strokeColor}">${char}</div>`;
            }
        };

        window.logActivity = function() {
            const today = new Date().toISOString().split('T')[0];
            window.activityLog[today] = (window.activityLog[today] || 0) + 1;
        };

        window.updateGamificationUI = function() {
            const today = new Date();
            let streak = 0;
            for(let i=0; i<365; i++) {
                const d = new Date(today);
                d.setDate(d.getDate() - i);
                const dateStr = d.toISOString().split('T')[0];
                if(window.activityLog[dateStr] > 0) streak++;
                else if (i !== 0) break;
            }
            document.getElementById('streak-count').textContent = streak;
            const fire = document.getElementById('streak-fire');
            if(streak > 0) {
                fire.classList.remove('opacity-30', 'grayscale');
                fire.classList.add('animate-pulse');
            } else {
                fire.classList.add('opacity-30', 'grayscale');
                fire.classList.remove('animate-pulse');
            }

            const calendar = document.getElementById('grass-calendar');
            calendar.innerHTML = '';
            for(let i=6; i>=0; i--) {
                const d = new Date(today);
                d.setDate(d.getDate() - i);
                const dateStr = d.toISOString().split('T')[0];
                const count = window.activityLog[dateStr] || 0;
                let lvl = '';
                if(count > 20) lvl = 'level-4';
                else if(count > 10) lvl = 'level-3';
                else if(count > 5) lvl = 'level-2';
                else if(count > 0) lvl = 'level-1';
                calendar.innerHTML += `<div class="grass-cell ${lvl}" title="${dateStr}: ${count}번 학습"></div>`;
            }
        };

        window.updateFirebaseStat = async function(hanjaNo, isCorrect) {
            window.logActivity();
            if (!window.userId || !hanjaNo) return;
            if (isCorrect) { window.knownAnswers.add(hanjaNo); window.incorrectAnswers.delete(hanjaNo); }
            else { window.knownAnswers.delete(hanjaNo); window.incorrectAnswers.add(hanjaNo); }
            try { await setDoc(getUserDocRef(window.userId), { knownAnswers: Array.from(window.knownAnswers), incorrectAnswers: Array.from(window.incorrectAnswers), activityLog: window.activityLog }, { merge: true }); } catch(e) {}
        };

        window.markAnswer = async function(isCorrect) {
            if (window.filteredHanjaData.length === 0) return;
            window.triggerHaptic(isCorrect ? 'correct' : 'wrong');
            await window.updateFirebaseStat(window.filteredHanjaData[window.currentIndex].no, isCorrect);
            
            if (isCorrect) {
                window.animateCardChange(1);
            } else {
                const cardWrapper = window.cards.current.querySelector('.card-inner');
                if (cardWrapper) {
                    cardWrapper.classList.remove('animate-shake');
                    void cardWrapper.offsetWidth; 
                    cardWrapper.classList.add('animate-shake');
                }
            }
        };

        document.addEventListener('DOMContentLoaded', () => {
            const timerSetup = document.getElementById('sidebar-timer-setup');
            if(timerSetup) {
                timerSetup.addEventListener('click', e => {
                    const btn = e.target.closest('.timer-preset');
                    if (btn) {
                        window.triggerHaptic('tap');
                        document.querySelectorAll('.timer-preset').forEach(b => {
                            b.classList.remove('active', 'bg-accent-cyan-dark', 'text-white');
                            b.classList.add('bg-white', 'text-gray-600');
                        });
                        btn.classList.add('active', 'bg-accent-cyan-dark', 'text-white');
                        btn.classList.remove('bg-white', 'text-gray-600');
                    }
                });
            }
        });

        window.startFocusTimer = function() {
            window.triggerHaptic('tap');
            const activePreset = document.querySelector('.timer-preset.active');
            window.focusTotalTime = activePreset ? parseInt(activePreset.dataset.time) : 600;
            window.focusRemainingTime = window.focusTotalTime;
            
            const sidebar = document.getElementById('sidebar');
            if (!sidebar.classList.contains('-translate-x-full')) {
                window.toggleSidebar();
            }
            
            const timerPill = document.getElementById('global-timer-pill');
            if(timerPill) timerPill.classList.remove('hidden');
            
            const textEl = document.getElementById('global-timer-text');
            const m = Math.ceil(window.focusRemainingTime / 60);
            if(textEl) textEl.textContent = m;
            
            document.querySelectorAll('.timer-pie-sync').forEach(pie => {
                pie.style.background = `conic-gradient(#ef4444 100%, transparent 0%)`;
            });
            
            clearInterval(window.focusTimerInterval);
            
            window.focusTimerInterval = setInterval(() => {
                window.focusRemainingTime--;
                
                const percentage = (window.focusRemainingTime / window.focusTotalTime) * 100;
                document.querySelectorAll('.timer-pie-sync').forEach(pie => {
                    pie.style.background = `conic-gradient(#ef4444 ${percentage}%, transparent 0%)`;
                });
                
                if(textEl) textEl.textContent = Math.ceil(window.focusRemainingTime / 60);

                if(window.focusRemainingTime <= 0) { 
                    clearInterval(window.focusTimerInterval); 
                    window.showModal("🎉 집중 시간이 종료되었습니다! 잠시 휴식을 취하세요."); 
                    window.resetFocusTimer(); 
                    window.triggerHaptic('correct');
                    window.playCorrectSound();
                }
            }, 1000);
        }

        window.resetFocusTimer = function() { 
            clearInterval(window.focusTimerInterval); 
            const timerPill = document.getElementById('global-timer-pill');
            if(timerPill) timerPill.classList.add('hidden'); 
        }

        window.quizQuestions = [];
        window.currentQIdx = 0;
        window.quizScore = 0;
        window.quizCombo = 0;
        window.quizInterval = null;
        window.quizTimeLeft = 10;
        window.quizAutoNextTimer = null; 

        window.setQuizConfig = function(key, value, btnEl) {
            window.triggerHaptic('tap');
            window.quizSettings[key] = value;
            
            if (key === 'target') {
                if (btnEl) {
                    const parent = btnEl.parentElement;
                    parent.querySelectorAll('button').forEach(b => b.classList.remove('active', '!text-amber-600', '!border-amber-200'));
                    if (value === 'exam') {
                        btnEl.classList.add('active', '!text-amber-600', '!border-amber-200');
                    } else {
                        btnEl.classList.add('active');
                    }
                    document.getElementById('quiz-level-select').value = "";
                    document.getElementById('quiz-type-select').value = "";
                } else {
                    document.querySelectorAll('.quiz-target-btn').forEach(b => b.classList.remove('active', '!text-amber-600', '!border-amber-200'));
                    if (value.startsWith('level-')) document.getElementById('quiz-type-select').value = "";
                    else if (value.startsWith('type-')) document.getElementById('quiz-level-select').value = "";
                }
            } else if(btnEl) {
                const parent = btnEl.parentElement;
                parent.querySelectorAll('button').forEach(b => b.classList.remove('active'));
                btnEl.classList.add('active');
            }
        };

        window.startQuiz = function() {
            window.triggerHaptic('tap');
            if(audioCtx.state === 'suspended') audioCtx.resume();
            
            let pool = [];
            const target = window.quizSettings.target;
            let qCount = window.quizSettings.count === 999 ? 100 : window.quizSettings.count;

            if (target === 'exam') {
                pool = window.pastExamData;
                if (!pool || pool.length < 5) {
                    window.showModal(`기출문제 데이터가 부족합니다.`); 
                    return;
                }
                
                document.getElementById('quiz-intro').classList.add('hidden');
                document.getElementById('quiz-result').classList.add('hidden');
                document.getElementById('quiz-container').classList.remove('hidden');
                
                if(window.quizSettings.mode === 'time') {
                    document.getElementById('quiz-timer-pill').classList.remove('hidden');
                } else {
                    document.getElementById('quiz-timer-pill').classList.add('hidden');
                }
                
                const shuffledPool = [...pool].sort(() => 0.5 - Math.random());
                const selectedQ = shuffledPool.slice(0, Math.min(qCount, pool.length));
                
                window.quizQuestions = selectedQ.map(q => {
                    const shuffledOptions = [...q.options].sort(() => 0.5 - Math.random());
                    return {
                        type: q.type,
                        format: q.format || 'multiple-choice',
                        hanjaObj: { no: 0, hanja: q.keyword || "", huneum: q.answerInfo },
                        text: q.text,
                        options: shuffledOptions,
                        answerInfo: q.answerInfo,
                        targetWord: q.keyword 
                    };
                });
                
                window.currentQIdx = 0; 
                window.quizScore = 0; 
                window.quizCombo = 0;
                document.getElementById('quiz-score-display').textContent = `0 점`;
                window.renderQuizQuestion();
                return;
            }
            
            if (target === 'current') {
                pool = [...window.filteredHanjaData];
            } else if (target === 'all') {
                pool = [...window.hanjaData];
            } else if (target === 'incorrect') {
                pool = window.hanjaData.filter(h => window.incorrectAnswers.has(h.no));
            } else if (target === 'studied') {
                pool = window.hanjaData.filter(h => window.knownAnswers.has(h.no) || window.incorrectAnswers.has(h.no));
            } else if (target.startsWith('level-')) {
                const level = target.replace('level-', '');
                pool = window.hanjaData.filter(h => h.level && h.level.includes(level));
            } else if (target.startsWith('type-')) {
                const typeNo = parseInt(target.replace('type-', ''));
                pool = window.hanjaData.filter(h => h.typeNo === typeNo);
            }

            if (window.quizSettings.type === 'relation') {
                pool = pool.filter(item => (item.synonyms && item.synonyms.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/)) || (item.antonyms && item.antonyms.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/)));
                if(pool.length < 5) { 
                    window.showModal(`해당 범위에 유의어/반의어가 있는 한자가 부족합니다.<br>(최소 5개 필요, 현재 ${pool.length}개)`); 
                    return; 
                }
            } else {
                if(pool.length < 5) { 
                    window.showModal(`퀴즈 데이터가 부족합니다. (최소 5개 필요, 현재 ${pool.length}개)`); 
                    return; 
                }
            }

            document.getElementById('quiz-intro').classList.add('hidden');
            document.getElementById('quiz-result').classList.add('hidden');
            document.getElementById('quiz-container').classList.remove('hidden');
            
            if(window.quizSettings.mode === 'time') {
                document.getElementById('quiz-timer-pill').classList.remove('hidden');
            } else {
                document.getElementById('quiz-timer-pill').classList.add('hidden');
            }
            
            try {
                window.quizQuestions = generateQuizQuestions(qCount, pool);
                if(window.quizQuestions.length === 0) throw new Error("퀴즈 생성 실패");
            } catch(e) {
                window.quizQuestions = [];
                for(let i=0; i<Math.min(qCount, pool.length); i++) {
                    const h = pool[i];
                    window.quizQuestions.push({
                        type: "훈음 퀴즈", format: 'multiple-choice', hanjaObj: h,
                        text: `<span class="hanja-font text-[2.8rem] block my-4 text-accent-cyan-dark bg-gray-50 py-3 rounded-xl border border-gray-100 shadow-inner">${h.hanja}</span> 이 한자의 알맞은 뜻과 소리는?`,
                        options: getConfusingOptions(h, pool).map(opt => ({ text: opt.text, isCorrect: opt.isCorrect, isHanja: false })),
                        answerInfo: `${h.hanja} : ${h.huneum}`
                    });
                }
            }

            window.currentQIdx = 0; 
            window.quizScore = 0; 
            window.quizCombo = 0;
            document.getElementById('quiz-score-display').textContent = `0 점`;
            window.renderQuizQuestion();
        };

        function getConfusingOptions(correctHanjaObj, poolList, isHanja = false) {
            let opts = new Set();
            const correctText = isHanja ? correctHanjaObj.hanja : correctHanjaObj.huneum;
            opts.add(correctText);

            let confusingHanjas = [];
            if (correctHanjaObj.similarHanja) confusingHanjas.push(...(correctHanjaObj.similarHanja.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g) || []));
            if (correctHanjaObj.synonyms) confusingHanjas.push(...(correctHanjaObj.synonyms.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g) || []));
            if (correctHanjaObj.antonyms) confusingHanjas.push(...(correctHanjaObj.antonyms.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g) || []));
            
            const sameType = window.hanjaData.filter(h => h.typeNo === correctHanjaObj.typeNo && h.no !== correctHanjaObj.no);
            confusingHanjas.push(...sameType.map(h => h.hanja));
            confusingHanjas = [...new Set(confusingHanjas)].sort(() => 0.5 - Math.random());

            for (let ch of confusingHanjas) {
                if (opts.size >= 4) break;
                const hData = window.hanjaMap.get(ch);
                if (hData) opts.add(isHanja ? hData.hanja : hData.huneum);
            }

            let attempts = 0;
            while(opts.size < 4 && attempts < 100) {
                const rand = poolList[Math.floor(Math.random() * poolList.length)];
                if(rand) opts.add(isHanja ? rand.hanja : rand.huneum);
                attempts++;
            }
            return Array.from(opts).map(text => ({ text, isCorrect: text === correctText, isHanja })).sort(() => 0.5 - Math.random());
        }

        const getChosung = (str) => {
            const cho = ["ㄱ","ㄲ","ㄴ","ㄷ","ㄸ","ㄹ","ㅁ","ㅂ","ㅃ","ㅅ","ㅆ","ㅇ","ㅈ","ㅉ","ㅊ","ㅋ","ㅌ","ㅍ","ㅎ"];
            let result = "";
            for(let i=0; i<str.length; i++) {
                let code = str.charCodeAt(i) - 44032;
                if(code > -1 && code < 11172) result += cho[Math.floor(code/588)];
                else result += str.charAt(i);
            }
            return result;
        };

        function generateQuizQuestions(count, pool) {
            const questions = [];
            pool.sort(() => 0.5 - Math.random());
            let failAttempts = 0;

            for(let i=0; i<count; i++) {
                const h = pool[i % pool.length];
                
                let typeOptions = [0, 1, 3, 4, 5, 6, 7, 8, 10, 11]; 
                if (window.quizSettings.type === 'huneum') typeOptions = [0, 1];
                else if (window.quizSettings.type === 'word') typeOptions = [3, 4, 5];
                else if (window.quizSettings.type === 'game') typeOptions = [6, 7, 8];
                else if (window.quizSettings.type === 'relation') typeOptions = [10, 11];

                let type = typeOptions[Math.floor(Math.random() * typeOptions.length)];

                if (failAttempts > 20) type = 0; 
                
                let q = { hanjaObj: h, format: 'multiple-choice' };
                
                try {
                    if (type === 10) { 
                        let targetH = h;
                        let synMatch = targetH.synonyms ? targetH.synonyms.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g) : null;
                        if (!synMatch) {
                            const withSyn = pool.filter(item => item.synonyms && item.synonyms.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/) && !questions.some(q => q.hanjaObj && q.hanjaObj.no === item.no));
                            if (withSyn.length > 0) {
                                targetH = withSyn[Math.floor(Math.random() * withSyn.length)];
                                synMatch = targetH.synonyms.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g);
                            } else {
                                failAttempts++; i--; continue;
                            }
                        }
                        
                        const trueSynonymChar = synMatch[0]; 
                        const trueSynonymData = window.hanjaMap.get(trueSynonymChar);
                        const trueSynonymText = trueSynonymChar;

                        let opts = new Set();
                        opts.add(trueSynonymText);
                        let attempts2 = 0;
                        while(opts.size < 4 && attempts2 < 50) {
                            const r = window.hanjaData[Math.floor(Math.random() * window.hanjaData.length)];
                            if (r.hanja !== targetH.hanja && r.hanja !== trueSynonymChar && (!targetH.synonyms.includes(r.hanja))) {
                                opts.add(r.hanja); 
                            }
                            attempts2++;
                        }
                        if (opts.size < 4) { failAttempts++; i--; continue; }

                        q.type = "유의어 찾기";
                        q.text = `<span class="hanja-font text-[2.8rem] block my-4 text-accent-cyan-dark bg-gray-50 py-3 rounded-xl border border-gray-100 shadow-inner">${targetH.hanja}</span> 이 한자와 <strong>뜻이 비슷하거나 같은(유의어)</strong> 한자는?`;
                        q.options = Array.from(opts).map(o => ({ text: o, isCorrect: o === trueSynonymText, isHanja: true })).sort(() => 0.5 - Math.random());
                        q.answerInfo = `정답: ${trueSynonymChar} (${trueSynonymData ? trueSynonymData.huneum.split(',')[0] : '알 수 없음'}) / 원래 한자: ${targetH.hanja} (${targetH.huneum})`;
                        q.hanjaObj = targetH;
                    }
                    else if (type === 11) { 
                        let targetH = h;
                        let antMatch = targetH.antonyms ? targetH.antonyms.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g) : null;
                        if (!antMatch) {
                            const withAnt = pool.filter(item => item.antonyms && item.antonyms.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/) && !questions.some(q => q.hanjaObj && q.hanjaObj.no === item.no));
                            if (withAnt.length > 0) {
                                targetH = withAnt[Math.floor(Math.random() * withAnt.length)];
                                antMatch = targetH.antonyms.match(/[\u4e00-\u9fa5\uF900-\uFAFF]/g);
                            } else {
                                failAttempts++; i--; continue;
                            }
                        }
                        
                        const trueAntonymChar = antMatch[0]; 
                        const trueAntonymData = window.hanjaMap.get(trueAntonymChar);
                        const trueAntonymText = trueAntonymChar; 

                        let opts = new Set();
                        opts.add(trueAntonymText);
                        let attempts2 = 0;
                        while(opts.size < 4 && attempts2 < 50) {
                            const r = window.hanjaData[Math.floor(Math.random() * window.hanjaData.length)];
                            if (r.hanja !== targetH.hanja && r.hanja !== trueAntonymChar && (!targetH.antonyms.includes(r.hanja))) {
                                opts.add(r.hanja); 
                            }
                            attempts2++;
                        }
                        if (opts.size < 4) { failAttempts++; i--; continue; }

                        q.type = "반의어 찾기";
                        q.text = `<span class="hanja-font text-[2.8rem] block my-4 text-accent-cyan-dark bg-gray-50 py-3 rounded-xl border border-gray-100 shadow-inner">${targetH.hanja}</span> 이 한자와 <strong>뜻이 반대되는(반의어)</strong> 한자는?`;
                        q.options = Array.from(opts).map(o => ({ text: o, isCorrect: o === trueAntonymText, isHanja: true })).sort(() => 0.5 - Math.random());
                        q.answerInfo = `정답: ${trueAntonymChar} (${trueAntonymData ? trueAntonymData.huneum.split(',')[0] : '알 수 없음'}) / 원래 한자: ${targetH.hanja} (${targetH.huneum})`;
                        q.hanjaObj = targetH;
                    }
                    else if(type === 0) { 
                        q.type = "훈음 퀴즈";
                        q.text = `<span class="hanja-font text-[2.8rem] block my-4 text-accent-cyan-dark bg-gray-50 py-3 rounded-xl border border-gray-100 shadow-inner">${h.hanja}</span> 이 한자의 알맞은 뜻과 소리는?`;
                        q.options = getConfusingOptions(h, pool);
                        q.answerInfo = `${h.hanja} : ${h.huneum}`;
                    } else if(type === 1) { 
                        q.type = "한자 찾기";
                        q.text = `<span class="text-2xl font-bold text-accent-cyan-dark block my-4 bg-gray-50 py-4 rounded-xl border border-gray-100 shadow-inner">'${h.huneum}'</span> 뜻과 소리를 가진 한자는?`;
                        q.options = getConfusingOptions(h, pool, true);
                        q.answerInfo = `${h.hanja} : ${h.huneum}`;
                    } else if (type === 3) { 
                        let vMatch = null;
                        if(h.textbookWords) vMatch = h.textbookWords.match(/([가-힣]+)\(([\u4e00-\u9fa5\uF900-\uFAFF]{2,})\)/);
                        if(vMatch) {
                            const kor = vMatch[1], han = vMatch[2];
                            let fakeHan = han.replace(h.hanja, pool[(i+1)%pool.length].hanja);
                            if(fakeHan === han) fakeHan = han.substring(0, han.length-1) + pool[(i+1)%pool.length].hanja;

                            let opts = new Set([`${kor}(<span class="hanja-font">${fakeHan}</span>)`]);
                            let attempts = 0;
                            while(opts.size < 4 && attempts < 50) {
                                const rH = window.hanjaData[Math.floor(Math.random()*window.hanjaData.length)];
                                if(rH.textbookWords) {
                                    const m = rH.textbookWords.match(/([가-힣]+)\(([\u4e00-\u9fa5\uF900-\uFAFF]{2,})\)/);
                                    if(m) opts.add(`${m[1]}(<span class="hanja-font">${m[2]}</span>)`);
                                }
                                attempts++;
                            }
                            if(opts.size < 4) { failAttempts++; i--; continue; }
                            q.type = "잘못된 표기 찾기";
                            q.text = `다음 중 단어의 한자 표기가 <strong>잘못된 것</strong>은?`;
                            q.options = Array.from(opts).map((o, idx) => ({ text: o, isCorrect: idx === 0 })).sort(()=>0.5-Math.random());
                            q.answerInfo = `올바른 표기: ${kor}(${han})`;
                        } else { failAttempts++; i--; continue; }
                    } else if (type === 4) { 
                        let vMatch = null;
                        if(h.textbookWords) vMatch = h.textbookWords.match(/([가-힣]+)\(([\u4e00-\u9fa5\uF900-\uFAFF]{2,})\)/);
                        if(vMatch && vMatch[2].includes(h.hanja)) {
                            const kor = vMatch[1], han = vMatch[2];
                            const blankHan = han.replace(h.hanja, ' ◯ ');
                            q.type = "단어 빈칸 채우기";
                            q.text = `다음 단어의 빈칸에 들어갈 알맞은 한자는?<br><span class="text-xl font-bold text-accent-cyan-dark block mt-4 bg-gray-50 p-3 rounded-xl border border-gray-200 shadow-inner">${kor} (<span class="hanja-font">${blankHan}</span>)</span>`;
                            q.options = getConfusingOptions(h, pool, true);
                            q.answerInfo = `정답: ${h.hanja} (${h.huneum})`;
                        } else { failAttempts++; i--; continue; }
                    } else if (type === 5) { 
                        const wordsWithHanja = window.hanjaData.filter(x => x.textbookWords && x.textbookWords.includes(h.hanja));
                        if(wordsWithHanja.length >= 2) {
                            const w1 = wordsWithHanja[0].textbookWords.match(/([가-힣]+)\(([\u4e00-\u9fa5\uF900-\uFAFF]+)\)/);
                            const w2 = wordsWithHanja[1].textbookWords.match(/([가-힣]+)\(([\u4e00-\u9fa5\uF900-\uFAFF]+)\)/);
                            if(w1 && w2 && w1[2] !== w2[2]) {
                                q.type = "공통 한자 찾기";
                                q.text = `두 단어의 빈칸 ◯ 에 <strong>공통으로</strong> 들어갈 한자는?<br><div class="mt-4 flex flex-col gap-2"><span class="bg-gray-50 p-2 rounded border">${w1[1]} (<span class="hanja-font">${w1[2].replace(h.hanja, '◯')}</span>)</span><span class="bg-gray-50 p-2 rounded border">${w2[1]} (<span class="hanja-font">${w2[2].replace(h.hanja, '◯')}</span>)</span></div>`;
                                q.options = getConfusingOptions(h, pool, true);
                                q.answerInfo = `공통 한자: ${h.hanja} (${h.huneum})`;
                            } else { failAttempts++; i--; continue; }
                        } else { failAttempts++; i--; continue; }
                    } else if (type === 6) {
                        let vMatch = null;
                        if(h.textbookWords) {
                            const matches = [...h.textbookWords.matchAll(/([가-힣]+)\(([\u4e00-\u9fa5\uF900-\uFAFF]{2,})\)/g)];
                            if(matches.length > 0) vMatch = matches[Math.floor(Math.random() * matches.length)];
                        }
                        if(vMatch) {
                            const kor = vMatch[1], han = vMatch[2];
                            let charArray = han.split('');
                            let distractors = [];
                            while(charArray.length + distractors.length < Math.min(6, han.length + 3)) {
                                const rand = pool[Math.floor(Math.random() * pool.length)].hanja;
                                if(!charArray.includes(rand) && !distractors.includes(rand)) distractors.push(rand);
                            }
                            q.type = "단어 조립 퍼즐";
                            q.format = "word-builder";
                            q.text = `제시된 단어에 알맞은 한자를 <strong>순서대로</strong> 조합하세요.<br><span class="text-xl font-bold text-accent-cyan-dark block mt-4 bg-gray-50 p-3 rounded-xl border border-gray-200 shadow-inner">${kor}</span>`;
                            q.targetWord = han;
                            q.options = [...charArray, ...distractors].sort(()=>0.5-Math.random());
                            q.answerInfo = `정답: ${kor} (${han})`;
                        } else { failAttempts++; i--; continue; }
                    } else if (type === 7) {
                        if(pool.length >= 4) {
                            let selected = new Set([h]);
                            while(selected.size < 4) selected.add(pool[Math.floor(Math.random() * pool.length)]);
                            let pairs = Array.from(selected);
                            let deck = [];
                            pairs.forEach((p, index) => {
                                deck.push({ id: index, type: 'hanja', text: p.hanja });
                                deck.push({ id: index, type: 'huneum', text: p.huneum });
                            });
                            q.type = "스피드 짝맞추기";
                            q.format = "memory-match";
                            q.text = `한자와 훈음의 <strong>알맞은 짝</strong>을 모두 찾아 터치하세요!`;
                            q.deck = deck.sort(()=>0.5-Math.random());
                            q.answerInfo = pairs.map(p => `${p.hanja}(${p.huneum})`).join(', ');
                        } else { failAttempts++; i--; continue; }
                    } else if (type === 8) {
                        q.type = "순간 포착 플래시";
                        q.format = "flash-blitz";
                        q.text = `<div id="flash-target" class="hanja-font text-[3.5rem] my-4 text-accent-cyan-dark bg-gray-50 py-3 rounded-xl border border-gray-100 shadow-inner flex items-center justify-center h-[120px] transition-all duration-300">${h.hanja}</div> 방금 지나간 한자의 뜻과 소리는?`;
                        q.options = getConfusingOptions(h, pool);
                        q.answerInfo = `${h.hanja} : ${h.huneum}`;
                    }
                    
                    failAttempts = 0;
                    questions.push(q);
                } catch(e) {
                    questions.push({
                        type: "훈음 퀴즈", format: 'multiple-choice', hanjaObj: h,
                        text: `<span class="hanja-font text-[2.8rem] block my-4 text-accent-cyan-dark bg-gray-50 py-3 rounded-xl border border-gray-100 shadow-inner">${h.hanja}</span> 이 한자의 알맞은 뜻과 소리는?`,
                        options: getConfusingOptions(h, pool).map(opt => ({ text: opt.text, isCorrect: opt.isCorrect, isHanja: false })),
                        answerInfo: `${h.hanja} : ${h.huneum}`
                    });
                }
            }
            return questions;
        }

        window.renderQuizQuestion = function() {
            if(window.quizAutoNextTimer) clearTimeout(window.quizAutoNextTimer); 

            const q = window.quizQuestions[window.currentQIdx];
            document.getElementById('quiz-progress').textContent = `${window.currentQIdx + 1} ${window.quizSettings.count === 999 ? '번째' : `/ ${window.quizQuestions.length}`}`;
            document.getElementById('quiz-badge').textContent = q.type;
            document.getElementById('quiz-question').innerHTML = q.text;
            
            const optionsContainer = document.getElementById('quiz-options');
            optionsContainer.innerHTML = '';
            
            const cardWrapper = document.getElementById('quiz-card-wrapper');
            cardWrapper.classList.remove('animate-shake', 'animate-pop');

            const canvasContainer = document.getElementById('quiz-canvas-container');
            const canvasControls = document.getElementById('quiz-canvas-controls');
            
            // 캔버스 쓰기 포맷인 경우
            if (q.format === 'canvas-write') {
                canvasContainer.classList.remove('hidden');
                canvasControls.classList.remove('hidden');
                optionsContainer.classList.add('hidden');
                
                const targetId = 'quiz-target-char';
                const canvasId = 'quiz-drawing-board';
                
                window.initCanvas(canvasId, true);
                
                const submitBtn = document.getElementById('quiz-submit-drawing-btn');
                submitBtn.onclick = async () => {
                    window.logActivity();
                    window.triggerHaptic('tap');
                    
                    // 캔버스에 그려진 이미지 데이터를 추출
                    const canvasEl = document.getElementById(canvasId);
                    const base64Image = canvasEl.toDataURL('image/jpeg').split(',')[1];
                    
                    // AI에게 채점 요청 (정답 글자와 일치하는지 판단)
                    submitBtn.textContent = '채점 중...';
                    submitBtn.disabled = true;
                    
                    const prompt = `사용자가 그린 한자가 정답인 '${q.targetWord}'와 일치하는지 판별해줘. 조금 서툴게 그려졌더라도 알아볼 수 있다면 정답으로 인정해. 반드시 다음 JSON으로만 답변해: {"isCorrect": true 또는 false, "reason": "간단한 이유"}`;
                    
                    try {
                        const res = await callGeminiAPI(prompt, true, base64Image);
                        const clean = extractJSON(res);
                        const result = JSON.parse(clean);
                        
                        // 정답/오답 처리를 위해 임시 옵션 객체 생성
                        const pseudoOpt = { isCorrect: result.isCorrect };
                        window.handleQuizAnswer(null, pseudoOpt, q);
                        
                        // 정답 여부와 상관없이 정답 애니메이션 재생
                        window.animateAnswer(q.targetWord, targetId);
                        
                    } catch (e) {
                        window.showModal("채점 시스템에 오류가 발생했습니다. 다시 시도해주세요.");
                    } finally {
                        submitBtn.textContent = '제출하기';
                        submitBtn.disabled = false;
                    }
                };
            } else {
                canvasContainer.classList.add('hidden');
                canvasControls.classList.add('hidden');
                optionsContainer.classList.remove('hidden');
            
                if (q.format === 'word-builder') {
                    const slotsDiv = document.createElement('div');
                    slotsDiv.className = 'flex justify-center gap-2 mb-6';
                    const slots = [];
                    for(let j=0; j<q.targetWord.length; j++) {
                        const slot = document.createElement('div');
                        slot.className = 'w-14 h-14 border-b-[3px] border-gray-400 flex justify-center items-center hanja-font text-3xl text-accent-cyan-dark bg-gray-50/50 rounded-t-lg';
                        slotsDiv.appendChild(slot);
                        slots.push(slot);
                    }
                    optionsContainer.appendChild(slotsDiv);

                    const btnGrid = document.createElement('div');
                    btnGrid.className = 'grid grid-cols-3 gap-2';
                    let currentSlotIdx = 0;
                    let selectedStr = "";
                    
                    q.options.forEach((opt) => {
                        const btn = document.createElement('button');
                        btn.className = 'btn-neumorphic py-4 text-center hanja-font text-3xl font-bold';
                        btn.innerHTML = opt;
                        btn.onclick = () => {
                            window.logActivity();
                            if(currentSlotIdx < q.targetWord.length) {
                                slots[currentSlotIdx].innerHTML = opt;
                                selectedStr += opt;
                                currentSlotIdx++;
                                btn.disabled = true;
                                btn.classList.add('opacity-30');
                                window.triggerHaptic('tap');

                                if(currentSlotIdx === q.targetWord.length) {
                                    const isCorrect = selectedStr === q.targetWord;
                                    window.handleQuizAnswer(null, {isCorrect}, q);
                                }
                            }
                        };
                        btnGrid.appendChild(btn);
                    });
                    optionsContainer.appendChild(btnGrid);
                } 
                else if (q.format === 'memory-match') {
                    const grid = document.createElement('div');
                    grid.className = 'grid grid-cols-2 gap-2.5';
                    let firstSelection = null;
                    let matchedCount = 0;
                    
                    q.deck.forEach((item) => {
                        const btn = document.createElement('button');
                        btn.className = `btn-neumorphic py-5 px-2 text-center font-bold ${item.type==='hanja' ? 'hanja-font text-4xl' : 'text-[13px] break-keep'}`;
                        btn.innerHTML = item.text;
                        btn.dataset.id = item.id;
                        btn.onclick = () => {
                            window.logActivity();
                            if(btn.classList.contains('pointer-events-none') || btn === firstSelection) return;
                            window.triggerHaptic('tap');
                            
                            if(!firstSelection) {
                                firstSelection = btn;
                                btn.classList.add('border-accent-cyan', 'border-2', 'bg-white');
                            } else {
                                if(firstSelection.dataset.id === btn.dataset.id) { 
                                    btn.classList.add('bg-green-100', 'text-green-700', 'border-green-400', 'pointer-events-none');
                                    firstSelection.classList.remove('border-accent-cyan', 'border-2', 'bg-white');
                                    firstSelection.classList.add('bg-green-100', 'text-green-700', 'border-green-400', 'pointer-events-none');
                                    window.triggerHaptic('correct');
                                    window.playCorrectSound();
                                    matchedCount++;
                                    firstSelection = null;
                                    if(matchedCount === 4) setTimeout(()=> window.handleQuizAnswer(null, {isCorrect: true}, q), 300);
                                } else { 
                                    btn.classList.add('bg-red-100', 'text-red-700', 'border-red-400');
                                    firstSelection.classList.remove('border-accent-cyan', 'border-2', 'bg-white');
                                    firstSelection.classList.add('bg-red-100', 'text-red-700', 'border-red-400');
                                    window.triggerHaptic('wrong');
                                    window.playWrongSound();
                                    firstSelection = null;
                                    setTimeout(() => window.handleQuizAnswer(null, {isCorrect: false}, q), 300);
                                }
                            }
                        };
                        grid.appendChild(btn);
                    });
                    optionsContainer.appendChild(grid);
                } 
                else {
                    q.options.forEach((opt) => {
                        const btn = document.createElement('button');
                        btn.className = `btn-neumorphic w-full py-4 px-4 text-center font-bold text-sm transition-all ${opt.isHanja ? 'hanja-font text-[1.8rem]' : ''}`;
                        btn.innerHTML = opt.text;
                        btn.onclick = () => { 
                            window.logActivity();
                            window.triggerHaptic('tap'); 
                            window.handleQuizAnswer(btn, opt, q); 
                        };
                        optionsContainer.appendChild(btn);
                    });
                    
                    if(q.format === 'flash-blitz') {
                        Array.from(optionsContainer.children).forEach(b => b.disabled = true);
                        setTimeout(() => {
                            const el = document.getElementById('flash-target');
                            if(el) {
                                el.innerHTML = '❓';
                                el.classList.remove('text-accent-cyan-dark');
                                el.classList.add('text-gray-400');
                                Array.from(optionsContainer.children).forEach(b => b.disabled = false);
                            }
                        }, 500); 
                    }
                }
            }

            document.getElementById('quiz-feedback').classList.add('hidden');

            if(window.quizSettings.mode === 'time') {
                window.quizTimeLeft = 10;
                if (q.format === 'canvas-write') window.quizTimeLeft = 20; // 쓰기 문제는 20초 부여
                const pieTimer = document.getElementById('quiz-google-timer');
                pieTimer.style.background = `conic-gradient(#ef4444 100%, transparent 0%)`;
                
                clearInterval(window.quizInterval);
                window.quizInterval = setInterval(() => {
                    window.quizTimeLeft -= 0.1;
                    const maxTime = q.format === 'canvas-write' ? 20 : 10;
                    const pct = (window.quizTimeLeft / maxTime) * 100;
                    pieTimer.style.background = `conic-gradient(#ef4444 ${pct}%, transparent 0%)`;
                    
                    if(window.quizTimeLeft <= 0) {
                        clearInterval(window.quizInterval);
                        if(optionsContainer) Array.from(optionsContainer.children).forEach(b => b.classList.add('pointer-events-none'));
                        const submitBtn = document.getElementById('quiz-submit-drawing-btn');
                        if(submitBtn) submitBtn.disabled = true;
                        window.triggerHaptic('wrong');
                        window.handleQuizAnswer(null, {isCorrect: false}, q, true);
                    }
                }, 100);
            }
        };

        window.showCombo = function(count) {
            const el = document.getElementById('quiz-combo-text');
            if(!el) return;
            if(count < 2) { el.classList.remove('combo-animate'); el.style.opacity = '0'; return; }
            el.textContent = `🔥 ${count} COMBO!`;
            el.classList.remove('combo-animate');
            void el.offsetWidth;
            el.classList.add('combo-animate');
            el.style.opacity = '1';
        };

        window.handleQuizAnswer = function(btn, opt, qData, isTimeout = false) {
            if (window.quizInterval) clearInterval(window.quizInterval);
            const optionsContainer = document.getElementById('quiz-options');
            const cardWrapper = document.getElementById('quiz-card-wrapper');
            const submitBtn = document.getElementById('quiz-submit-drawing-btn');
            
            try {
                if(optionsContainer) {
                    Array.from(optionsContainer.children).forEach(b => {
                        b.classList.add('pointer-events-none', 'opacity-50');
                    });
                }
                if (submitBtn) submitBtn.disabled = true;
            } catch(e) {}

            const feedback = document.getElementById('quiz-feedback');
            feedback.classList.remove('hidden');

            if(opt.isCorrect) {
                cardWrapper.classList.add('animate-pop');
                window.triggerHaptic('correct');
                window.playCorrectSound(); 
                
                if(btn) {
                    btn.classList.remove('opacity-50');
                    btn.style.background = '#dcfce7'; 
                    btn.style.borderColor = '#4ade80';
                    btn.style.color = '#166534';
                }
                
                window.quizCombo++;
                window.showCombo(window.quizCombo);
                let point = 10 + (window.quizCombo > 1 ? window.quizCombo * 2 : 0);
                if(window.quizSettings.mode === 'time') point += Math.floor(window.quizTimeLeft);
                if(qData.format === 'canvas-write') point += 20; // 쓰기 정답 보너스
                window.quizScore += point;
                
                document.getElementById('quiz-score-display').textContent = `${window.quizScore} 점`;
                feedback.innerHTML = `✅ <strong>정답입니다! (+${point}점)</strong><br><span class="text-xs text-gray-600 mt-1 block">${qData.answerInfo}</span>`;
                feedback.className = 'p-4 rounded-xl font-bold text-sm text-center mb-1 bg-green-50 border border-green-200 text-green-700 shadow-sm';
                if(qData.hanjaObj && qData.hanjaObj.no) window.updateFirebaseStat(qData.hanjaObj.no, true);

            } else {
                cardWrapper.classList.add('animate-shake');
                window.triggerHaptic('wrong');
                window.playWrongSound(); 
                
                window.quizQuestions.push(qData);
                document.getElementById('quiz-progress').textContent = `${window.currentQIdx + 1} / ${window.quizQuestions.length}`;

                window.quizCombo = 0;
                window.showCombo(window.quizCombo);
                if(btn) {
                    btn.classList.remove('opacity-50');
                    btn.style.background = '#fee2e2';
                    btn.style.borderColor = '#f87171';
                    btn.style.color = '#991b1b';
                }
                
                if((qData.format === 'multiple-choice' || qData.format === 'flash-blitz') && optionsContainer) {
                    try {
                        const correctIdx = qData.options.findIndex(x => x.isCorrect);
                        const correctBtn = optionsContainer.children[correctIdx];
                        if(correctBtn) {
                            correctBtn.classList.remove('opacity-50');
                            correctBtn.style.background = '#dcfce7';
                            correctBtn.style.borderColor = '#4ade80';
                            correctBtn.style.color = '#166534';
                        }
                    } catch(e) {}
                }

                feedback.innerHTML = `❌ <strong>${isTimeout ? '시간 초과!' : '오답입니다.'}</strong><br><span class="text-[11px] text-gray-600 mt-1.5 block">${qData.answerInfo}</span>`;
                feedback.className = 'p-4 rounded-xl font-bold text-sm text-center mb-1 bg-red-50 border border-red-200 text-red-700 shadow-sm';
                if(qData.hanjaObj && qData.hanjaObj.no) window.updateFirebaseStat(qData.hanjaObj.no, false);
                
                if(window.quizSettings.count === 999) { 
                    setTimeout(window.endQuiz, 1500); return;
                }
            }
            
            window.quizAutoNextTimer = setTimeout(() => {
                if(!document.getElementById('quiz-container').classList.contains('hidden')) {
                    window.nextQuizQuestion();
                }
            }, qData.format === 'canvas-write' ? 3000 : 2000); // 쓰기는 애니메이션을 보기 위해 딜레이 추가
        };

        window.nextQuizQuestion = function() {
            window.currentQIdx++;
            if(window.currentQIdx < window.quizQuestions.length) window.renderQuizQuestion();
            else window.endQuiz();
        };

        window.endQuiz = function() {
            if(window.quizAutoNextTimer) clearTimeout(window.quizAutoNextTimer);
            document.getElementById('quiz-container').classList.add('hidden');
            document.getElementById('quiz-result').classList.remove('hidden');
            document.getElementById('quiz-final-score').textContent = window.quizScore;
            
            let msg = "";
            if(window.quizSettings.count === 999) msg = `서바이벌 모드에서 총 ${window.currentQIdx}문제를 맞혔습니다! 🔥`;
            else if(window.quizScore >= window.quizSettings.count * 10 * 0.8) msg = "완벽해요! 한자 마스터에 등극하셨습니다. 🏆 (오답 복습까지 완벽!)";
            else if(window.quizScore >= window.quizSettings.count * 10 * 0.5) msg = "좋아요! 꾸준한 학습이 실력을 만듭니다. 💪";
            else msg = "모든 오답을 복습하느라 고생하셨습니다! 🔥";
            
            document.getElementById('quiz-result-msg').textContent = msg;
        }

        // 🎮 아케이드 모드 (산성비) 시스템
        window.arcadeDifficulty = 'normal';
        window.arcadeInputMode = 'all'; 
        window.arcadeTarget = 'current';
        window.arcadeInitialLives = 3;
        
        window.setArcadeDifficulty = function(diff, btn) {
            window.triggerHaptic('tap');
            window.arcadeDifficulty = diff;
            document.querySelectorAll('.arcade-diff-btn').forEach(b => {
                b.classList.remove('active', '!text-purple-600', '!text-red-500');
            });
            btn.classList.add('active');
            if(diff === 'hell') btn.classList.add('!text-red-500');
            else btn.classList.add('!text-purple-600');
        };

        window.setArcadeInputMode = function(mode, btn) {
            window.triggerHaptic('tap');
            window.arcadeInputMode = mode;
            document.querySelectorAll('.arcade-mode-btn').forEach(b => {
                b.classList.remove('active', '!text-purple-600');
            });
            btn.classList.add('active', '!text-purple-600');
        };

        window.setArcadeLives = function(lives, btn) {
            window.triggerHaptic('tap');
            window.arcadeInitialLives = lives;
            document.querySelectorAll('.arcade-lives-btn').forEach(b => {
                b.classList.remove('active', '!text-purple-600', 'text-green-600', '!text-green-600');
                if(b.textContent.includes('무제한')) b.classList.add('text-green-600');
            });
            btn.classList.add('active');
            if(lives === 999) btn.classList.add('!text-green-600');
            else btn.classList.add('!text-purple-600');
        };

        window.setArcadeTarget = function(target, btn) {
            window.triggerHaptic('tap');
            window.arcadeTarget = target;
            
            if (btn) {
                const parent = btn.parentElement;
                parent.querySelectorAll('button').forEach(b => b.classList.remove('active', '!text-purple-600'));
                btn.classList.add('active', '!text-purple-600');
                document.getElementById('arcade-level-select').value = "";
                document.getElementById('arcade-type-select').value = "";
            } else {
                document.querySelectorAll('.arcade-target-btn').forEach(b => b.classList.remove('active', '!text-purple-600'));
                if (target.startsWith('level-')) document.getElementById('arcade-type-select').value = "";
                else if (target.startsWith('type-')) document.getElementById('arcade-level-select').value = "";
            }
            
            let targetText = target;
            if(target === 'current') targetText = '현재 필터';
            else if(target === 'all') targetText = '전체';
            else if(target === 'studied') targetText = '학습완료';
            else if(target === 'incorrect') targetText = '오답노트';
            else if(target.startsWith('level-')) targetText = target.replace('level-', '');
            else if(target.startsWith('type-')) targetText = target.replace('type-', '유형 ');
            
            const tl = document.getElementById('arcade-target-level');
            if(tl) tl.textContent = targetText;
        };

        window.arcadeState = {
            active: false,
            score: 0,
            lives: 3,
            words: [],
            speed: 1,
            spawnRate: 2000,
            speedInc: 0.02,
            spawnInc: 20,
            minSpawn: 800,
            lastSpawn: 0,
            animFrame: null,
            pool: []
        };

        window.startArcade = function() {
            window.triggerHaptic('tap');
            if(audioCtx.state === 'suspended') audioCtx.resume();
            
            let pool = [];
            const target = window.arcadeTarget;
            
            if (target === 'current') {
                pool = [...window.filteredHanjaData];
            } else if (target === 'all') {
                pool = [...window.hanjaData];
            } else if (target === 'incorrect') {
                pool = window.hanjaData.filter(h => window.incorrectAnswers.has(h.no));
            } else if (target === 'studied') {
                const readHanja = window.filteredHanjaData.slice(0, window.currentIndex + 1);
                const markedHanja = window.hanjaData.filter(h => window.knownAnswers.has(h.no) || window.incorrectAnswers.has(h.no));
                pool = Array.from(new Set([...readHanja, ...markedHanja]));
            } else if (target.startsWith('level-')) {
                const level = target.replace('level-', '');
                pool = window.hanjaData.filter(h => h.level && h.level.includes(level));
            } else if (target.startsWith('type-')) {
                const typeNo = parseInt(target.replace('type-', ''));
                pool = window.hanjaData.filter(h => h.typeNo === typeNo);
            }

            if(pool.length < 5) { window.showModal(`게임 데이터가 부족합니다. (최소 5개 필요, 현재 ${pool.length}개)`); return; }

            document.getElementById('arcade-intro').classList.add('hidden');
            document.getElementById('arcade-game').classList.remove('hidden');
            document.getElementById('arcade-result').classList.add('hidden');
            document.getElementById('arcade-sky').innerHTML = '';
            document.getElementById('arcade-missed-container').innerHTML = '';
            document.getElementById('arcade-input').value = '';
            document.getElementById('arcade-input').focus();
            
            let initSpeed, initSpawnRate, speedInc, spawnInc, minSpawn;
            switch(window.arcadeDifficulty) {
                case 'easy': initSpeed = 0.3; initSpawnRate = 2500; speedInc = 0.01; spawnInc = 10; minSpawn = 1200; break;
                case 'hard': initSpeed = 0.8; initSpawnRate = 1500; speedInc = 0.03; spawnInc = 30; minSpawn = 600; break;
                case 'hell': initSpeed = 1.3; initSpawnRate = 1000; speedInc = 0.05; spawnInc = 50; minSpawn = 400; break;
                case 'normal':
                default:     initSpeed = 0.5; initSpawnRate = 2000; speedInc = 0.02; spawnInc = 20; minSpawn = 800; break;
            }

            window.arcadeState = {
                active: true, score: 0, lives: window.arcadeInitialLives, words: [], 
                speed: initSpeed, spawnRate: initSpawnRate, 
                speedInc: speedInc, spawnInc: spawnInc, minSpawn: minSpawn,
                lastSpawn: Date.now(), pool: pool,
                shuffledPool: [...pool].sort(() => 0.5 - Math.random()),
                poolIdx: 0
            };
            
            window.updateArcadeUI();
            window.arcadeLoop();
        };

        window.stopArcade = function() {
            window.arcadeState.active = false;
            if(window.arcadeState.animFrame) cancelAnimationFrame(window.arcadeState.animFrame);
        };

        window.spawnArcadeWord = function() {
            if (window.arcadeState.poolIdx >= window.arcadeState.shuffledPool.length) {
                window.arcadeState.shuffledPool.sort(() => 0.5 - Math.random());
                window.arcadeState.poolIdx = 0;
            }
            const h = window.arcadeState.shuffledPool[window.arcadeState.poolIdx++];
            
            const el = document.createElement('div');
            el.className = 'falling-word bg-white border border-gray-200 text-text-main hanja-font';
            el.textContent = h.hanja;
            
            const validAnswers = [];
            
            const addValid = (word) => {
                if (word && !validAnswers.includes(word)) validAnswers.push(word);
            };

            h.huneum.split(/[,|/]/).forEach(part => {
                let textOnly = part.replace(/\(.*?\)/g, ''); 
                textOnly = textOnly.replace(/[^가-힣\s]/g, ''); 
                const cleanPart = textOnly.replace(/\s+/g, '');
                
                let altText = '';
                const altMatch = part.match(/\((.*?)\)/);
                if (altMatch) {
                    altText = altMatch[1].replace(/[^가-힣\s]/g, '').replace(/\s+/g, '');
                }

                if(cleanPart.length > 0) {
                    if (window.arcadeInputMode === 'all' || window.arcadeInputMode === 'huneum') {
                        addValid(cleanPart);
                        if (altText) {
                            if (altText.length === 1) addValid(cleanPart.slice(0, -1) + altText);
                            else addValid(altText);
                        }
                    }
                    if (window.arcadeInputMode === 'all' || window.arcadeInputMode === 'sound') {
                        addValid(cleanPart.charAt(cleanPart.length - 1));
                        
                        const words = textOnly.trim().split(/\s+/);
                        if(words.length > 0) addValid(words[words.length - 1]);
                        
                        if (altText) {
                            if (altText.length === 1) addValid(altText);
                            else addValid(altText.charAt(altText.length - 1));
                        }
                    }
                }
            });
            
            const sky = document.getElementById('arcade-sky');
            sky.appendChild(el);
            
            const maxX = sky.clientWidth - 50;
            const x = Math.max(10, Math.random() * maxX);
            
            const wordObj = { id: Date.now() + Math.random(), el, x, y: -40, answers: validAnswers, no: h.no, marked: false, huneum: h.huneum, hanja: h.hanja };
            el.style.left = x + 'px';
            el.style.top = wordObj.y + 'px';
            
            window.arcadeState.words.push(wordObj);
            window.arcadeState.speed += window.arcadeState.speedInc; 
            window.arcadeState.spawnRate = Math.max(window.arcadeState.minSpawn, window.arcadeState.spawnRate - window.arcadeState.spawnInc); 
        };

        window.updateArcadeUI = function() {
            document.getElementById('arcade-score').textContent = window.arcadeState.score;
            
            const livesEl = document.getElementById('arcade-lives');
            if (window.arcadeState.lives >= 999) {
                livesEl.textContent = '❤️ 무제한 (연습 모드)';
            } else if (window.arcadeInitialLives > 5) {
                livesEl.textContent = `❤️ x ${window.arcadeState.lives}`;
            } else {
                livesEl.textContent = '❤️'.repeat(Math.max(0, window.arcadeState.lives)) + '💔'.repeat(Math.max(0, window.arcadeInitialLives - window.arcadeState.lives));
            }
        };

        window.checkArcadeInput = function() {
            if(!window.arcadeState.active) return;
            const input = document.getElementById('arcade-input');
            
            const val = input.value.replace(/[^가-힣]/g, '');
            if(!val) return;

            const sortedWords = [...window.arcadeState.words].sort((a,b) => b.y - a.y);
            
            for(let i=0; i<sortedWords.length; i++) {
                const w = sortedWords[i];
                if(w.marked) continue;
                
                const isCorrect = w.answers.some(ans => {
                    if (val === ans) return true;
                    if ((window.arcadeInputMode === 'all' || window.arcadeInputMode === 'huneum') && ans.length > val.length && val.length > 1 && ans.endsWith(val)) {
                        return true;
                    }
                    return false;
                });
                
                if(isCorrect) {
                    w.marked = true;
                    
                    input.blur(); 
                    input.value = ''; 
                    setTimeout(() => { if(input) input.focus(); }, 10); 

                    window.playCorrectSound();
                    window.triggerHaptic('correct');
                    window.arcadeState.score += Math.floor(10 * window.arcadeState.speed);
                    window.updateArcadeUI();
                    
                    w.el.classList.add('explode');
                    setTimeout(() => {
                        if(w.el.parentNode) w.el.parentNode.removeChild(w.el);
                        window.arcadeState.words = window.arcadeState.words.filter(item => item.id !== w.id);
                    }, 300);
                    
                    window.updateFirebaseStat(w.no, true);
                    return; 
                }
            }
        };

        window.arcadeLoop = function() {
            if(!window.arcadeState.active) return;
            
            const now = Date.now();
            if(now - window.arcadeState.lastSpawn > window.arcadeState.spawnRate) {
                window.spawnArcadeWord();
                window.arcadeState.lastSpawn = now;
            }
            
            const skyHeight = document.getElementById('arcade-sky').clientHeight;
            
            for(let i = window.arcadeState.words.length - 1; i >= 0; i--) {
                const w = window.arcadeState.words[i];
                if(w.marked) continue;
                
                w.y += window.arcadeState.speed;
                w.el.style.top = w.y + 'px';
                
                if(w.y > skyHeight - 30) {
                    window.arcadeState.words.splice(i, 1);
                    if(w.el.parentNode) w.el.parentNode.removeChild(w.el);
                    
                    const missedContainer = document.getElementById('arcade-missed-container');
                    const badge = document.createElement('div');
                    badge.className = 'missed-badge flex items-center gap-1 bg-red-100 border border-red-300 text-red-800 px-2 py-0.5 rounded-lg shadow-sm';
                    badge.innerHTML = `<span class="hanja-font text-[16px] font-black">${w.hanja}</span><span class="text-[10px] font-bold">${w.huneum}</span>`;
                    missedContainer.appendChild(badge);
                    
                    missedContainer.scrollTop = missedContainer.scrollHeight;

                    window.playWrongSound();
                    window.triggerHaptic('wrong');
                    
                    if (window.arcadeState.lives < 999) {
                        window.arcadeState.lives--;
                    }
                    
                    window.updateArcadeUI();
                    window.updateFirebaseStat(w.no, false);
                    
                    if(window.arcadeState.lives <= 0) {
                        window.endArcade();
                        return;
                    }
                }
            }
            
            window.arcadeState.animFrame = requestAnimationFrame(window.arcadeLoop);
        };

        window.endArcade = function() {
            window.stopArcade();
            document.getElementById('arcade-game').classList.add('hidden');
            document.getElementById('arcade-result').classList.remove('hidden');
            document.getElementById('arcade-final-score').textContent = window.arcadeState.score;
        };

