                    </div>`).join('');

                html += `<div class="bg-white/60 p-4 rounded-2xl border border-[#dfd6c2] shadow-sm">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="w-[60px] h-[60px] flex-shrink-0 bg-white rounded-xl shadow-md border-2 border-accent-cyan/20 flex items-center justify-center hanja-font text-[2rem] font-bold text-accent-cyan-dark cursor-pointer" data-hanjadata="${encodeURIComponent(JSON.stringify(rep))}" onclick="window.showDetailFromType(this)">${rep.hanja}</div>
                        <div class="flex-1 min-w-0"><p class="font-bold text-base text-text-main mb-1 truncate">${rep.huneum}</p><span class="bg-accent-cyan-dark text-white px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wider">Type ${t}</span></div>
