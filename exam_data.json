<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, maximum-scale=1.0">
    <title>프리미엄 한자 학습</title>
    
    <link rel="manifest" href="data:application/json;base64,">
    <meta name="theme-color" content="#f8f5ed">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/hanzi-writer@3.5/dist/hanzi-writer.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+KR:wght@400;700&family=Nanum+Myeongjo:wght@700&display=swap" rel="stylesheet">
    
    <style>
        @font-face {
            font-family: 'NanumSquareNeo';
            src: url('https://cdn.jsdelivr.net/gh/projectnoonnu/noonfonts_11-01@1.0/NanumSquareNeo-Variable.woff2') format('woff2');
            font-weight: normal;
            font-style: normal;
        }

        :root {
            --bg-paper: #f8f5ed;
            --bg-dark: #e8e2d2;
            --bg-card: #dfd6c2;
            --text-main: #2d2d2d;
            --text-light: #595959;
            --accent-cyan: #2b6cb0;
            --accent-cyan-dark: #2c5282;
            --shadow-light: rgba(255, 255, 255, 0.6);
            --shadow-dark: rgba(139, 131, 110, 0.3);
            --grid-color: #fca5a5;
            --grid-center: #f87171;
        }
        
        body.dark-mode {
            --bg-paper: #121212; 
            --bg-dark: #18181b; 
            --bg-card: #1f1f23; 
            --text-main: #f8fafc; 
            --text-light: #cbd5e1; 
            --accent-cyan: #38bdf8; 
            --accent-cyan-dark: #7dd3fc;
            --shadow-light: rgba(255,255,255,0.03);
            --shadow-dark: rgba(0,0,0,0.6);
            --grid-color: #334155;
            --grid-center: #475569;
            background-image: none !important;
            background-color: var(--bg-paper) !important;
        }
        
        body.dark-mode .bg-white { background-color: var(--bg-card) !important; border-color: #3f3f46 !important; color: var(--text-main); }
        
        body.dark-mode .bg-white\/60, 
        body.dark-mode .bg-white\/70, 
        body.dark-mode .bg-white\/80, 
        body.dark-mode .bg-white\/90 { 
            background-color: rgba(31, 31, 35, 0.85) !important; 
            border-color: rgba(255, 255, 255, 0.08) !important; 
            color: var(--text-main);
        }
        
        body.dark-mode .bg-gray-50 { background-color: #27272a !important; border-color: #3f3f46 !important; color: var(--text-main); }
        body.dark-mode .bg-gray-50\/50 { background-color: rgba(39, 39, 42, 0.5) !important; }
        body.dark-mode .bg-gray-100 { background-color: #27272a !important; border-color: #3f3f46 !important; }
        body.dark-mode .bg-[#eaf4f4] { background-color: rgba(56, 189, 248, 0.1) !important; border-color: rgba(56, 189, 248, 0.2) !important; }
        
        body.dark-mode .text-gray-800, body.dark-mode .text-gray-900, body.dark-mode .text-black { color: #f8fafc !important; }
        body.dark-mode .text-gray-700 { color: #e2e8f0 !important; }
        body.dark-mode .text-gray-600 { color: #cbd5e1 !important; }
        body.dark-mode .text-gray-500 { color: #94a3b8 !important; }
        body.dark-mode .text-gray-400 { color: #64748b !important; }
        body.dark-mode .text-gray-300 { color: #475569 !important; }
        
        body.dark-mode .text-blue-600, body.dark-mode .text-blue-700 { color: #60a5fa !important; } 
        body.dark-mode .text-purple-600, body.dark-mode .text-purple-700 { color: #c084fc !important; } 
        body.dark-mode .text-teal-600, body.dark-mode .text-emerald-600, body.dark-mode .text-emerald-700 { color: #34d399 !important; } 
        body.dark-mode .text-rose-600, body.dark-mode .text-rose-500, body.dark-mode .text-red-500, body.dark-mode .text-red-600, body.dark-mode .text-red-700 { color: #fb7185 !important; } 
        body.dark-mode .text-amber-600 { color: #fbbf24 !important; } 
        
        body.dark-mode .border-gray-200, body.dark-mode .border-gray-100 { border-color: #3f3f46 !important; }
        body.dark-mode .shadow-sm, body.dark-mode .shadow-md { box-shadow: 0 4px 6px -1px rgba(0,0,0,0.6) !important; }
        
        body.dark-mode .bg-blue-50 { background-color: rgba(56, 189, 248, 0.15) !important; border-color: rgba(56, 189, 248, 0.3) !important; color: #bae6fd !important;}
        body.dark-mode .bg-red-50 { background-color: rgba(251, 113, 133, 0.15) !important; border-color: rgba(251, 113, 133, 0.3) !important; color: #fecdd3 !important;}
        body.dark-mode .bg-green-50, body.dark-mode .bg-emerald-50 { background-color: rgba(52, 211, 153, 0.15) !important; border-color: rgba(52, 211, 153, 0.3) !important; color: #a7f3d0 !important;}
        body.dark-mode .bg-orange-50 { background-color: rgba(251, 191, 36, 0.15) !important; border-color: rgba(251, 191, 36, 0.3) !important; color: #fde68a !important;}
        body.dark-mode .bg-purple-50 { background-color: rgba(192, 132, 252, 0.15) !important; border-color: rgba(192, 132, 252, 0.3) !important; color: #e9d5ff !important;}
        body.dark-mode .card-face { background-image: none !important; }

        body { 
            font-family: 'NanumSquareNeo', sans-serif; 
            background-color: var(--bg-paper);
            background-image: url('https://www.transparenttextures.com/patterns/rice-paper-3.png');
            color: var(--text-light); 
            -webkit-tap-highlight-color: transparent; 
            -webkit-font-smoothing: antialiased;
            user-select: none;
            margin: 0; padding: 0;
            height: 100dvh; width: 100vw;
            overflow: hidden; 
            display: flex; justify-content: center;
            transition: background-color 0.3s, color 0.3s;
        }
        
        .hanja-font { 
            font-family: 'Kaiti', 'STKaiti', 'AR PL UKai TW', 'AR PL UKai HK', 'AR PL UKai CN', 'KaiTi', '楷体', 'BiauKai', 'Gungsuh', 'GungSeo', 'Noto Serif KR', 'Nanum Myeongjo', 'Batang', serif !important; 
            font-weight: 400 !important; 
            text-shadow: 1px 1px 0px rgba(255,255,255,0.2);
        }
        body.dark-mode .hanja-font { text-shadow: 2px 2px 4px rgba(0,0,0,0.5); }
        
        .view-section { 
            width: 100%; max-width: 28rem; 
            height: 100%; 
            display: flex; flex-direction: column; 
            padding: 0.75rem; 
            padding-bottom: env(safe-area-inset-bottom, 1rem); 
            transition: opacity 0.3s ease; 
        }
        #main-view { overflow: hidden; }
        .scrollable-view { overflow-y: auto; }
        .hidden-view { display: none !important; }

        .card-container { perspective: 1800px; position: relative; touch-action: pan-y; }
        
        .card-wrapper { 
            position: absolute; width: 100%; height: 100%; top: 0; left: 0;
            transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1), opacity 0.3s ease-out;
            transform-style: preserve-3d; 
            transform-origin: center center;
            will-change: transform, opacity;
        }

        .card-inner {
            position: absolute; width: 100%; height: 100%; top: 0; left: 0;
            transition: transform 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
            transform-style: preserve-3d;
            border-radius: 1.5rem; 
            will-change: transform;
        }
        .card-inner.is-flipped { transform: rotateY(180deg); }
        
        .card-face { 
            position: absolute; width: 100%; height: 100%; 
            -webkit-backface-visibility: hidden; backface-visibility: hidden; 
            transform: translateZ(0);
            display: flex; flex-direction: column; justify-content: center; 
            align-items: center; border-radius: 1.5rem; 
            background-color: var(--bg-card);
            background-image: url('https://www.transparenttextures.com/patterns/rice-paper-3.png');
            box-shadow: 8px 8px 16px var(--shadow-dark), -4px -4px 12px var(--shadow-light);
            padding: 1rem; overflow: hidden; 
        }
        .card-front { transform: rotateY(0deg) translate3d(0, 0, 1px); }
        .card-back { transform: rotateY(180deg) translate3d(0, 0, 1px); }
        
        .btn-neumorphic {
            background: linear-gradient(145deg, #f0eadd, #d4cebf);
            border-radius: 8px; border: 1px solid rgba(255,255,255,0.2);
            color: var(--text-light); font-weight: 700; 
            box-shadow: 3px 3px 6px var(--shadow-dark), -3px -3px 6px var(--shadow-light);
            transition: transform 0.1s, box-shadow 0.1s;
        }
        body.dark-mode .btn-neumorphic {
            background: linear-gradient(145deg, #27272a, #1c1c1f) !important;
            border: 1px solid rgba(255,255,255,0.06) !important;
            color: #e2e8f0 !important;
            box-shadow: 3px 3px 6px var(--shadow-dark), -3px -3px 6px var(--shadow-light) !important;
        }
        .btn-neumorphic:active { transform: translateY(1px); box-shadow: inset 2px 2px 4px var(--shadow-dark); }
        .btn-neumorphic.active { background: #fff; color: var(--accent-cyan); box-shadow: inset 2px 2px 4px rgba(0,0,0,0.1); }
        body.dark-mode .btn-neumorphic.active { 
            background: #3f3f46 !important; 
            color: var(--accent-cyan-dark) !important; 
            box-shadow: inset 2px 2px 4px rgba(0,0,0,0.4) !important; 
            border-color: rgba(0,0,0,0.5) !important;
        }
        .btn-neumorphic:disabled { opacity: 0.5; box-shadow: none; transform: none; cursor: not-allowed; }

        .info-badge {
            background-color: rgba(255, 255, 255, 0.5); padding: 0.2rem 0.6rem; border-radius: 999px;
            font-size: 10px; font-weight: 700; color: var(--text-main);
            border: 1px solid rgba(0, 0, 0, 0.05);
        }
        body.dark-mode .info-badge { background-color: rgba(0,0,0,0.5); color: #e2e8f0; border-color: rgba(255,255,255,0.1); }
        
        .info-badge-container {
            position: absolute; top: 1rem; left: 1rem; right: 1rem;
            display: flex; justify-content: space-between; align-items: center; pointer-events: none;
            -webkit-backface-visibility: hidden; backface-visibility: hidden; transform: translateZ(2px);
            z-index: 50;
        }
        .info-badge-container > * { pointer-events: auto; }

        .huneum-overlay { backdrop-filter: blur(2px); }
        .no-scrollbar::-webkit-scrollbar { display: none; }
        
        .canvas-grid {
            background-color: var(--bg-card);
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><line x1="0" y1="0" x2="100" y2="100" stroke="%23fca5a5" stroke-width="0.4" stroke-dasharray="2 2" /><line x1="100" y1="0" x2="0" y2="100" stroke="%23fca5a5" stroke-width="0.4" stroke-dasharray="2 2" /><line x1="50" y1="0" x2="50" y2="100" stroke="%23ef4444" stroke-width="0.8" stroke-dasharray="3 3" /><line x1="0" y1="50" x2="100" y2="50" stroke="%23ef4444" stroke-width="0.8" stroke-dasharray="3 3" /></svg>');
            background-size: 100% 100%;
        }
        body.dark-mode .canvas-grid {
            background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><line x1="0" y1="0" x2="100" y2="100" stroke="%23334155" stroke-width="0.4" stroke-dasharray="2 2" /><line x1="100" y1="0" x2="0" y2="100" stroke="%23334155" stroke-width="0.4" stroke-dasharray="2 2" /><line x1="50" y1="0" x2="50" y2="100" stroke="%23475569" stroke-width="0.8" stroke-dasharray="3 3" /><line x1="0" y1="50" x2="100" y2="50" stroke="%23475569" stroke-width="0.8" stroke-dasharray="3 3" /></svg>') !important;
        }
        
        @keyframes combo-pop {
            0% { transform: scale(0.8) rotate(-5deg); opacity: 0; }
            50% { transform: scale(1.3) rotate(5deg); opacity: 1; }
            100% { transform: scale(1) rotate(0deg); opacity: 1; }
        }
        .combo-animate { animation: combo-pop 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; }

        @keyframes shake {
            0%, 100% { transform: translateX(0); }
            20%, 60% { transform: translateX(-5px) rotate(-1deg); }
            40%, 80% { transform: translateX(5px) rotate(1deg); }
        }
        .animate-shake { animation: shake 0.4s ease-in-out; }

        @keyframes popOut {
            0% { transform: scale(0.95); }
            50% { transform: scale(1.02); }
            100% { transform: scale(1); }
        }
        .animate-pop { animation: popOut 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); }

        /* 아케이드 모드 애니메이션 */
        @keyframes explode {
            0% { transform: scale(1); opacity: 1; filter: brightness(1); }
            50% { transform: scale(1.5); opacity: 0.8; filter: brightness(2); }
            100% { transform: scale(2); opacity: 0; filter: brightness(3); }
        }
        .falling-word { position: absolute; font-weight: bold; padding: 4px 10px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); z-index: 10; font-size: 1.5rem; transition: transform 0.1s; }
        .falling-word.explode { animation: explode 0.3s ease-out forwards; pointer-events: none; }
        
        /* 오답 시 정답(훈음) 폭발 애니메이션 (선명하게 1.8초 머무름) */
        @keyframes explode-wrong {
            0% { transform: scale(1) translateY(0); opacity: 1; }
            15% { transform: scale(1.4) translateY(-20px); opacity: 1; box-shadow: 0 10px 15px -3px rgba(239, 68, 68, 0.4); }
            85% { transform: scale(1.4) translateY(-20px); opacity: 1; box-shadow: 0 10px 15px -3px rgba(239, 68, 68, 0.4); }
            100% { transform: scale(1.2) translateY(10px); opacity: 0; }
        }
        .falling-word.explode-wrong { 
            animation: explode-wrong 1.8s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards; 
            pointer-events: none; 
            color: #dc2626 !important; 
            background-color: #fee2e2 !important; 
            border: 2px solid #ef4444 !important;
            font-family: 'NanumSquareNeo', sans-serif !important;
            font-size: 1.3rem !important; 
            font-weight: 900 !important;
            padding: 8px 16px !important;
            white-space: nowrap;
            text-shadow: none;
            z-index: 100;
        }
        
        /* 떨어진 오답 한자 스택 뱃지 애니메이션 */
        @keyframes popIn {
            0% { transform: scale(0.5); opacity: 0; }
            100% { transform: scale(1); opacity: 1; }
        }
        .missed-badge {
            animation: popIn 0.3s ease-out forwards;
        }
        
        /* 어원 모핑 애니메이션 */
        @keyframes morph-emoji-in {
            0% { transform: scale(0) rotate(-10deg); opacity: 0; }
            50% { transform: scale(1.2) rotate(5deg); opacity: 1; }
            100% { transform: scale(1) rotate(0deg); opacity: 1; }
        }
        @keyframes morph-emoji-out {
            0% { transform: scale(1); opacity: 1; }
            100% { transform: scale(0.5); opacity: 0; filter: blur(4px); }
        }
        
        .google-timer-pie {
            background: conic-gradient(#ef4444 100%, transparent 0%);
        }
        
        .grass-cell { width: 14px; height: 14px; border-radius: 3px; background-color: #e5e7eb; transition: background-color 0.3s; border: 1px solid rgba(0,0,0,0.05); }
        body.dark-mode .grass-cell { background-color: #3f3f46; border-color: rgba(255,255,255,0.05); }
        .grass-cell.level-1 { background-color: #9be9a8; }
        .grass-cell.level-2 { background-color: #40c463; }
        .grass-cell.level-3 { background-color: #30a14e; }
        .grass-cell.level-4 { background-color: #216e39; }
        body.dark-mode .grass-cell.level-1 { background-color: #064e3b; }
        body.dark-mode .grass-cell.level-2 { background-color: #047857; }
        body.dark-mode .grass-cell.level-3 { background-color: #10b981; }
        body.dark-mode .grass-cell.level-4 { background-color: #34d399; }
    </style>
</head>
<body class="relative transition-colors duration-300">

    <div id="global-timer-pill" class="hidden fixed top-3 right-4 z-[300] pointer-events-auto bg-white/90 border border-[#dfd6c2] rounded-full p-1 flex items-center justify-center shadow-md cursor-pointer backdrop-blur-sm transition-transform hover:scale-105 active:scale-95" onclick="window.resetFocusTimer()" title="타이머 종료">
        <div class="relative w-9 h-9 flex items-center justify-center">
            <div class="absolute inset-0 timer-pie-sync google-timer-pie transition-all duration-1000 ease-linear rounded-full"></div>
            <div class="absolute inset-1 bg-[#f8f5ed] rounded-full flex items-center justify-center shadow-inner">
                <span id="global-timer-text" class="text-[12px] font-black text-gray-700 font-mono">10</span>
            </div>
        </div>
    </div>

    <div id="sidebar-overlay" class="fixed inset-0 bg-black/40 z-[250] hidden backdrop-blur-sm transition-opacity" onclick="window.toggleSidebar()"></div>
    <div id="sidebar" class="fixed inset-y-0 left-0 w-64 bg-[#f8f5ed] shadow-2xl z-[300] transform -translate-x-full transition-transform duration-300 flex flex-col p-5 overflow-y-auto border-r border-[#dfd6c2] no-scrollbar">
        <div class="flex justify-between items-center mb-5">
            <h2 class="text-xl font-bold text-text-main hanja-font drop-shadow-sm">프리미엄 한자</h2>
            <div class="flex gap-3 items-center">
                <button onclick="window.toggleDarkMode()" class="text-xl text-gray-600 active:scale-90" id="dark-mode-btn">🌙</button>
                <button onclick="window.toggleSidebar()" class="text-3xl text-gray-500 active:scale-90">&times;</button>
            </div>
        </div>
        
        <div class="mb-5 p-3 bg-white rounded-xl shadow-sm border border-gray-200 flex flex-col items-center">
            <div class="text-xs font-bold text-gray-500 mb-1 flex items-center gap-1"><span class="text-lg" id="streak-fire">🔥</span> 연속 학습 달성</div>
            <div class="text-[13px] font-bold text-text-main mb-3"><span id="streak-count" class="text-red-500 text-lg font-black mx-1">0</span>일째 학습 중!</div>
            <div class="flex gap-1.5 justify-center w-full" id="grass-calendar"></div>
            <div class="text-[9px] text-gray-400 mt-2">최근 7일 학습 기록</div>
        </div>
        
        <h3 class="text-[11px] font-bold text-accent-cyan-dark mb-2 uppercase tracking-widest px-1">메뉴</h3>
        <div class="grid grid-cols-2 gap-2 mb-5" id="sidebar-mode-selector">
            <button data-mode="read" class="active py-2.5 text-[13px] font-bold bg-white rounded-xl shadow-sm border border-gray-200 text-gray-600 transition-colors">📖 읽기</button>
            <button data-mode="write" class="py-2.5 text-[13px] font-bold bg-white rounded-xl shadow-sm border border-gray-200 text-gray-600 transition-colors">✍️ 쓰기</button>
            <button data-mode="quiz" class="py-2.5 text-[13px] font-bold bg-white rounded-xl shadow-sm border border-gray-200 text-gray-600 transition-colors">📝 퀴즈</button>
            <button data-mode="type" class="py-2.5 text-[13px] font-bold bg-white rounded-xl shadow-sm border border-gray-200 text-gray-600 transition-colors">🗂️ 유형</button>
            <button data-mode="wordbook" class="py-2.5 text-[13px] font-bold bg-white rounded-xl shadow-sm border border-gray-200 text-gray-600 transition-colors">📔 단어</button>
            <button data-mode="arcade" class="py-2.5 text-[13px] font-bold bg-white rounded-xl shadow-sm border border-gray-200 text-purple-600 transition-colors">🕹️ 게임</button>
            <button data-mode="news-link" class="py-2.5 text-[13px] font-bold bg-white rounded-xl shadow-sm border border-gray-200 text-gray-600 transition-colors">📰 뉴스</button>
            <button data-mode="scan" class="py-2.5 text-[13px] font-bold bg-white rounded-xl shadow-sm border border-gray-200 text-gray-600 transition-colors">📷 스캔</button>
        </div>

        <h3 class="text-[11px] font-bold text-accent-cyan-dark mb-2 uppercase tracking-widest px-1">학습 범위 (필터)</h3>
        <div class="flex flex-wrap gap-1.5 mb-5" id="sidebar-level-selector">
            <button data-level="스마트" class="px-3 py-1.5 text-[12px] font-bold bg-blue-50 border border-blue-200 rounded-full shadow-sm text-blue-700 transition-colors w-full text-center mb-1">🧠 스마트 복습 (AI 추천)</button>
            <button data-level="전체" class="active px-3 py-1.5 text-[12px] font-bold bg-white border border-gray-200 rounded-full shadow-sm text-gray-600 transition-colors duration-200">전체</button>
            <button data-level="8급" class="px-3 py-1.5 text-[12px] font-bold bg-white border border-gray-200 rounded-full shadow-sm text-gray-600 transition-colors duration-200">8급</button>
            <button data-level="7급" class="px-3 py-1.5 text-[12px] font-bold bg-white border border-gray-200 rounded-full shadow-sm text-gray-600 transition-colors duration-200">7급</button>
            <button data-level="6급" class="px-3 py-1.5 text-[12px] font-bold bg-white border border-gray-200 rounded-full shadow-sm text-gray-600 transition-colors duration-200">6급</button>
            <button data-level="5급" class="px-3 py-1.5 text-[12px] font-bold bg-white border border-gray-200 rounded-full shadow-sm text-gray-600 transition-colors duration-200">5급</button>
            <button data-level="4급" class="px-3 py-1.5 text-[12px] font-bold bg-white border border-gray-200 rounded-full shadow-sm text-gray-600 transition-colors duration-200">4급</button>
            <button data-level="3급" class="px-3 py-1.5 text-[12px] font-bold bg-white border border-gray-200 rounded-full shadow-sm text-gray-600 transition-colors duration-200">3급</button>
            <button data-level="2급" class="px-3 py-1.5 text-[12px] font-bold bg-white border border-gray-200 rounded-full shadow-sm text-gray-600 transition-colors duration-200">2급</button>
            <button data-level="암기" class="px-3 py-1.5 text-[12px] font-bold bg-green-50 border border-green-200 rounded-full shadow-sm text-green-700 transition-colors duration-200">✅ 암기완료</button>
